{
  "extends": "@school/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@school/ui": [
        "../../packages/ui/src"
      ],
      "@school/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@school/shared": [
        "../../packages/shared/src"
      ],
      "@school/shared/*": [
        "../../packages/shared/src/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
