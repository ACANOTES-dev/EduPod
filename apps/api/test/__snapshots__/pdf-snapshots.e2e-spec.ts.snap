      color: #111827;
      font-size: 13px;
      background: white;
      direction: rtl;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    @page { size: A4; margin: 0; }
  </style>
</head>
<body>
  <!-- Header bar -->
  <table style="width: 100%; border-collapse: collapse; margin-bottom: 28px;">
    <tr>
      <td style="padding: 0;">
        <div style="background: #047857; color: white; padding: 20px 24px;">
          <table style="width: 100%; border-collapse: collapse;">
            <tr>
              <td style="vertical-align: middle;">
                <div style="font-size: 22px; font-weight: 700; letter-spacing: 0.5px;">كشف حساب</div>
                <div style="font-size: 14px; font-weight: 400; margin-top: 4px; opacity: 0.9;">مدرسة النور الدولية</div>
              </td>
              <td style="vertical-align: middle; text-align: left; width: 140px;">
                <img src="https://example.com/logo.png" alt="" style="height: 50px; max-width: 120px; object-fit: contain; border-radius: 4px;" onerror="this.style.display='none'">
              </td>
            </tr>
          </table>
        </div>
      </td>
    </tr>
  </table>

  <div style="padding: 0 24px;">
    <!-- Account holder & period info -->
    <table style="width: 100%; border-collapse: collapse; margin-bottom: 24px;">
      <tr>
        <td style="vertical-align: top; width: 50%;">
          <div style="font-size: 10px; color: #6b7280; font-weight: 600; letter-spacing: 0.5px; margin-bottom: 6px;">صاحب الحساب</div>
          <div style="font-size: 15px; font-weight: 700; color: #111827;">Al-Rashid Family</div>
          <div style="font-size: 12px; color: #4b5563; margin-top: 2px;">Ahmed Al-Rashid</div>
        </td>
        <td style="vertical-align: top; text-align: left; width: 50%;">
          <table style="margin-right: auto; border-collapse: collapse;">
            <tr>
              <td style="padding: 3px 0 3px 16px; font-size: 11px; color: #6b7280; font-weight: 500;">الفترة:</td>
              <td style="padding: 3px 0; font-size: 11px; font-weight: 600;" dir="ltr">01 Sept 2025 &ndash; 16 Mar 2026</td>
            </tr>
            <tr>
              <td style="padding: 3px 0 3px 16px; font-size: 11px; color: #6b7280; font-weight: 500;">الرصيد الافتتاحي:</td>
              <td style="padding: 3px 0; font-size: 11px; font-weight: 700; font-family: 'Courier New', monospace;" dir="ltr">AED 0.00</td>
            </tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- Ledger Table -->
    <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
      <thead>
        <tr style="background: #047857; color: white;">
          <th style="padding: 10px 12px; text-align: right; font-weight: 600; font-size: 11px; width: 80px;">التاريخ</th>
          <th style="padding: 10px 12px; text-align: right; font-weight: 600; font-size: 11px; width: 72px;">النوع</th>
          <th style="padding: 10px 12px; text-align: right; font-weight: 600; font-size: 11px; width: 110px;">المرجع</th>
          <th style="padding: 10px 12px; text-align: right; font-weight: 600; font-size: 11px;">الوصف</th>
          <th style="padding: 10px 12px; text-align: left; font-weight: 600; font-size: 11px; width: 100px;">مدين</th>
          <th style="padding: 10px 12px; text-align: left; font-weight: 600; font-size: 11px; width: 100px;">دائن</th>
          <th style="padding: 10px 12px; text-align: left; font-weight: 600; font-size: 11px; width: 100px;">الرصيد</th>
        </tr>
      </thead>
      <tbody>
        
      <tr style="background: #ffffff;">
        <td style="padding: 8px 12px; border-bottom: 1px solid #e5e7eb; font-size: 11px; white-space: nowrap;" dir="ltr">15 Sept 2025</td>
        <td style="padding: 8px 12px; border-bottom: 1px solid #e5e7eb; font-size: 11px;">فاتورة</td>
        <td style="padding: 8px 12px; border-bottom: 1px solid #e5e7eb; font-size: 11px; font-family: 'Courier New', monospace; max-width: 130px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" dir="ltr">INV-202509-0001</td>
