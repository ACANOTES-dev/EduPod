exports[`PDF Template Snapshots Invoice AR: renders deterministic HTML 1`] = `
"<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;500;600;700&display=swap');
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Noto Sans Arabic', 'Arial', sans-serif; color: #111827; font-size: 14px; background: white; direction: rtl; }
    @page { size: A4; margin: 0; }
  </style>
</head>
<body>
  <div style="padding: 0;">
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 3px solid #047857; padding-bottom: 16px; margin-bottom: 24px;">
      <div>
        <h1 style="font-size: 28px; font-weight: 700; color: #047857; letter-spacing: -0.5px;">فاتورة</h1>
        <p style="font-size: 16px; font-weight: 600; margin-top: 4px;">مدرسة النور الدولية</p>
      </div>
      <img src="https://example.com/logo.png" alt="الشعار" style="height: 60px; max-width: 120px; object-fit: contain;">
    </div>

    <!-- Invoice Meta + Billing Info -->
    <div style="display: flex; justify-content: space-between; margin-bottom: 28px;">
      <div>
        <p style="font-size: 12px; color: #6b7280; font-weight: 600; margin-bottom: 4px;">فاتورة إلى</p>
        <p style="font-size: 14px; font-weight: 600;">Al-Rashid Family</p>
        <p style="font-size: 13px; color: #374151;">عناية: Ahmed Al-Rashid</p>
        <p style="font-size: 13px; color: #374151; line-height: 1.8; margin-top: 4px;">123 Palm Jumeirah<br>Apt 4B<br>Dubai 12345<br>UAE</p>
      </div>
      <div>
        <table style="font-size: 13px;">
          <tr>
            <td style="padding: 3px 0 3px 12px; color: #6b7280; font-weight: 500;">رقم الفاتورة:</td>
            <td style="padding: 3px 0; font-weight: 600;" dir="ltr">INV-202603-0001</td>
          </tr>
          <tr><td style="padding: 3px 0 3px 12px; color: #6b7280; font-weight: 500;">تاريخ الإصدار:</td><td style="padding: 3px 0;" dir="ltr">01 مارس 2026</td></tr>
          <tr>
            <td style="padding: 3px 0 3px 12px; color: #6b7280; font-weight: 500;">تاريخ الاستحقاق:</td>
            <td style="padding: 3px 0;" dir="ltr">31 مارس 2026</td>
          </tr>
          <tr>
            <td style="padding: 3px 0 3px 12px; color: #6b7280; font-weight: 500;">الحالة:</td>
            <td style="padding: 3px 0;"><span style="color: #2563eb; font-weight: 600;">صادرة</span></td>
          </tr>
        </table>
      </div>
    </div>

    <!-- Line Items -->
    <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
      <thead>
        <tr style="background: #047857; color: white;">
          <th style="padding: 10px 8px; text-align: right; font-weight: 600;">الوصف</th>
          <th style="padding: 10px 8px; text-align: center; font-weight: 600; width: 80px;">الكمية</th>
          <th style="padding: 10px 8px; text-align: left; font-weight: 600; width: 120px;">سعر الوحدة</th>
          <th style="padding: 10px 8px; text-align: left; font-weight: 600; width: 120px;">المبلغ</th>
        </tr>
      </thead>
      <tbody>
        
      <tr>
        <td style="padding: 10px 8px; border-bottom: 1px solid #e5e7eb;">Tuition Fee — Term 1</td>
        <td style="padding: 10px 8px; border-bottom: 1px solid #e5e7eb; text-align: center;" dir="ltr">1</td>
        <td style="padding: 10px 8px; border-bottom: 1px solid #e5e7eb; text-align: left;" dir="ltr">AED 15000.00</td>
        <td style="padding: 10px 8px; border-bottom: 1px solid #e5e7eb; text-align: left; font-weight: 500;" dir="ltr">AED 15000.00</td>
      </tr>
      <tr>
        <td style="padding: 10px 8px; border-bottom: 1px solid #e5e7eb;">Activity Fee — Term 1</td>
        <td style="padding: 10px 8px; border-bottom: 1px solid #e5e7eb; text-align: center;" dir="ltr">1</td>
        <td style="padding: 10px 8px; border-bottom: 1px solid #e5e7eb; text-align: left;" dir="ltr">AED 2000.00</td>
        <td style="padding: 10px 8px; border-bottom: 1px solid #e5e7eb; text-align: left; font-weight: 500;" dir="ltr">AED 2000.00</td>
      </tr>
      </tbody>
    </table>

    <!-- Totals -->
    <div style="display: flex; justify-content: flex-start; margin-top: 16px;">
      <table style="font-size: 13px; min-width: 280px;">
        <tr>
          <td style="padding: 6px 0 6px 16px; color: #6b7280;">المجموع الفرعي:</td>
          <td style="padding: 6px 0; text-align: left;" dir="ltr">AED 17000.00</td>
        </tr>
        <tr><td style="padding: 6px 0 6px 16px; color: #6b7280;">الخصم:</td><td style="padding: 6px 0; text-align: left; color: #16a34a;" dir="ltr">-AED 500.00</td></tr>
        <tr style="border-top: 2px solid #047857;">
          <td style="padding: 10px 0 6px 16px; font-weight: 700; font-size: 15px;">الإجمالي:</td>
