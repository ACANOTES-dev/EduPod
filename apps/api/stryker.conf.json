{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "packageManager": "pnpm",
  "reporters": ["clear-text", "html"],
  "testRunner": "jest",
  "jest": {
    "configFile": "jest.config.js"
  },
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "mutate": [
    "src/modules/auth/auth.service.ts",
    "src/modules/finance/invoices.service.ts",
    "src/modules/finance/payments.service.ts",
    "src/modules/behaviour/behaviour-sanctions.service.ts",
    "src/modules/behaviour/safeguarding-concerns.service.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "timeoutMS": 60000,
  "concurrency": 2
}
