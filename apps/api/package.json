    "handlebars": "^4.7.9",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "isomorphic-dompurify": "^3.5.1",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^13.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
