    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.3.0",
    "@prisma/client": "^6.1.0",
    "@school/prisma": "workspace:*",
    "@school/shared": "workspace:*",
    "@sentry/nestjs": "^10.44.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
