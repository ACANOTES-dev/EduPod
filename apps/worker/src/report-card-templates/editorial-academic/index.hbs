<!doctype html>
<html lang="{{lang_attr}}" dir="{{direction}}" data-medium="print">
  <head>
    <meta charset="utf-8" />
    <title>{{report_title}} — {{student.full_name}} — {{period_name}}, {{academic_year}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700&family=Fraunces:opsz,wght,SOFT@9..144,300..900,0..100&family=JetBrains+Mono:wght@400;500;600&family=Noto+Naskh+Arabic:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html { font-size: 16px; }
      html[data-medium='print'] body {
        background: #fff !important;
        padding: 0 !important;
      }
      img { max-width: 100%; display: block; }
      table { border-collapse: collapse; }
      @page { size: A4; margin: 0; }

      :root {
        --paper: #faf6ec;
        --paper-deep: #f4efdd;
        --paper-shadow: #ebe4c8;
        --ink: #1a1812;
        --ink-soft: #3a362e;
        --ink-muted: #6b655a;
        --ink-light: #a09a8d;
        --accent: #1f3a2a;
        --accent-mid: #2d5340;
        --accent-soft: #4a7059;
        --gold: #a37f3e;
        --gold-light: #c9a669;
        --gold-pale: #e3d2a8;
        --hairline: rgba(26, 24, 18, 0.12);
        --hairline-strong: rgba(26, 24, 18, 0.22);
        --hairline-gold: rgba(163, 127, 62, 0.35);
        --hairline-gold-strong: rgba(163, 127, 62, 0.55);
        --font-display: 'Fraunces', 'Noto Naskh Arabic', Georgia, 'Times New Roman', serif;
        --font-body: 'Fraunces', 'Noto Naskh Arabic', Georgia, 'Times New Roman', serif;
        --font-label: 'Archivo', 'Noto Naskh Arabic', 'Helvetica Neue', Helvetica, sans-serif;
        --font-mono: 'JetBrains Mono', 'SF Mono', Menlo, Consolas, monospace;
      }

      html[lang='ar'] {
        --font-display: 'Noto Naskh Arabic', 'Fraunces', Georgia, serif;
        --font-body: 'Noto Naskh Arabic', 'Fraunces', Georgia, serif;
        --font-label: 'Noto Naskh Arabic', 'Archivo', 'Helvetica Neue', sans-serif;
      }

      body {
        font-family: var(--font-body);
        font-weight: 400;
        font-size: 10.5pt;
        line-height: 1.5;
        color: var(--ink);
        background: var(--paper);
        -webkit-font-smoothing: antialiased;
        font-feature-settings: 'kern', 'liga', 'onum';
      }

      .page {
        width: 210mm;
        height: 297mm;
        padding: 16mm 18mm 12mm;
        background: var(--paper);
        position: relative;
        overflow: hidden;
        page-break-after: always;
        background-image:
          radial-gradient(circle at 15% 25%, rgba(163, 127, 62, 0.025) 0%, transparent 50%),
          radial-gradient(circle at 85% 75%, rgba(163, 127, 62, 0.018) 0%, transparent 50%);
      }
      .page:last-of-type { page-break-after: auto; }

      .watermark {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
        z-index: 0;
        color: var(--accent);
        opacity: 0.04;
      }
      .watermark svg { width: 68%; height: auto; max-width: 440px; }

      .page-frame {
        position: absolute;
        inset: 9mm;
        border: 0.5px solid var(--hairline-gold);
        pointer-events: none;
        z-index: 0;
      }
      .page-frame::before {
        content: '';
        position: absolute;
        inset: 2mm;
        border: 0.25px solid var(--hairline-gold);
      }

      .corner-diamond {
        position: absolute;
        width: 6px;
        height: 6px;
        background: var(--gold);
        transform: rotate(45deg);
        z-index: 2;
      }
      .corner-tl { top: calc(9mm - 3px); inset-inline-start: calc(9mm - 3px); }
      .corner-tr { top: calc(9mm - 3px); inset-inline-end: calc(9mm - 3px); }
      .corner-bl { bottom: calc(9mm - 3px); inset-inline-start: calc(9mm - 3px); }
      .corner-br { bottom: calc(9mm - 3px); inset-inline-end: calc(9mm - 3px); }

      .page-inner {
        position: relative;
        z-index: 1;
        height: calc(297mm - 28mm);
        display: flex;
        flex-direction: column;
      }

      .masthead {
        position: relative;
        text-align: center;
        padding-block: 0.25rem 1.25rem;
        margin-block-end: 1.5rem;
        border-block-end: 0.5px solid var(--hairline);
      }
      .masthead-eyebrow {
        font-family: var(--font-label);
        font-size: 8.5pt;
        font-weight: 500;
        letter-spacing: 0.38em;
        text-transform: uppercase;
        color: var(--gold);
        margin-block-end: 0.65rem;
      }
      .masthead-school {
        font-family: var(--font-display);
        font-variation-settings: 'opsz' 144, 'wght' 400, 'SOFT' 40;
        font-size: 28pt;
        line-height: 1.15;
        color: var(--accent);
        margin-block-end: 0.2rem;
        letter-spacing: -0.012em;
      }
      .masthead-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.85rem;
        margin-block: 0.7rem 0.55rem;
        color: var(--gold);
      }
      .masthead-divider::before,
      .masthead-divider::after {
        content: '';
        height: 0.5px;
        width: 70px;
        background: currentColor;
      }
      .masthead-divider svg { width: 13px; height: 13px; }
      .masthead-title {
        font-family: var(--font-label);
        font-size: 9pt;
        font-weight: 600;
        letter-spacing: 0.5em;
        text-transform: uppercase;
        color: var(--ink-soft);
        margin-block-end: 0.55rem;
      }
      .masthead-meta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.1rem;
        font-family: var(--font-body);
        font-size: 9.5pt;
        color: var(--ink-soft);
        font-style: italic;
      }
      html[lang='ar'] .masthead-meta { font-style: normal; }
      html[lang='ar'] .masthead-eyebrow,
      html[lang='ar'] .masthead-title { letter-spacing: 0; text-transform: none; }
      .masthead-meta .sep {
        color: var(--gold);
        font-style: normal;
        font-size: 11pt;
      }

      .rank-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        margin-block-start: 0.75rem;
        padding: 0.25rem 0.75rem;
        border: 0.75px solid var(--gold);
        color: var(--accent);
        font-family: var(--font-label);
        font-size: 8pt;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }
      html[lang='ar'] .rank-badge { letter-spacing: 0; text-transform: none; }
      .rank-badge svg { width: 11px; height: 11px; color: var(--gold); }

      .section { margin-block-end: 1.4rem; }
      .section-label {
        display: flex;
        align-items: baseline;
        gap: 0.85rem;
        margin-block-end: 0.75rem;
      }
      .section-label-num {
        font-family: var(--font-display);
        font-size: 10pt;
        font-style: italic;
        color: var(--gold);
        letter-spacing: 0.02em;
        min-width: 1.3rem;
      }
      .section-label-text {
        font-family: var(--font-label);
        font-size: 8.5pt;
        font-weight: 600;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--ink);
      }
      html[lang='ar'] .section-label-text { letter-spacing: 0; text-transform: none; font-size: 10pt; }
      .section-label-rule {
        flex: 1;
        height: 0.5px;
        background: var(--hairline-strong);
        align-self: center;
      }

      .student-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.95rem 2.2rem;
        padding-block: 0.35rem 0.15rem;
      }
      .detail-field {
        display: flex;
        flex-direction: column;
        gap: 0.18rem;
      }
      .detail-label {
        font-family: var(--font-label);
        font-size: 7pt;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--ink-muted);
      }
      html[lang='ar'] .detail-label { letter-spacing: 0; text-transform: none; font-size: 8.5pt; }
      .detail-value {
        font-family: var(--font-body);
        font-size: 11pt;
        color: var(--ink);
        border-block-end: 0.5px solid var(--hairline);
        padding-block-end: 0.18rem;
      }
      .detail-value.mono {
        font-family: var(--font-mono);
        font-size: 9.5pt;
      }

      .subjects-table {
        width: 100%;
        margin-block-start: 0.25rem;
      }
      .subjects-table thead th {
        font-family: var(--font-label);
        font-size: 7pt;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--ink-muted);
        text-align: start;
        padding: 0.45rem 0.5rem 0.4rem;
        border-block-end: 1px solid var(--hairline-strong);
      }
      html[lang='ar'] .subjects-table thead th { letter-spacing: 0; text-transform: none; font-size: 9pt; }
      .subjects-table thead th.num,
      .subjects-table thead th.grade-h {
        text-align: center;
        width: 10%;
      }
      .subjects-table thead th.remark { width: 48%; }
      .subjects-table tbody td {
        padding: 0.5rem 0.5rem 0.48rem;
        border-block-end: 0.5px solid var(--hairline);
        vertical-align: top;
      }
      .subjects-table tbody tr:last-child td {
        border-block-end: 1px solid var(--hairline-strong);
      }
      .subject-name {
        font-family: var(--font-display);
        font-size: 10.5pt;
        font-weight: 500;
        color: var(--ink);
      }
      .subject-mark {
        font-family: var(--font-mono);
        font-size: 9.5pt;
        font-weight: 500;
        color: var(--ink);
        text-align: center;
        font-variant-numeric: tabular-nums;
      }
      .subject-grade {
        font-family: var(--font-display);
        font-size: 11.5pt;
        font-weight: 600;
        color: var(--accent);
        text-align: center;
      }
      .subject-remark {
        font-family: var(--font-body);
        font-size: 9pt;
        font-style: italic;
        color: var(--ink-soft);
        line-height: 1.5;
        padding-inline-end: 0.2rem;
      }
      html[lang='ar'] .subject-remark { font-style: normal; }
      .subject-remark.empty { color: var(--ink-light); }

      .summary-card {
        padding: 1rem 1.1rem 1.15rem;
        border: 0.5px solid var(--hairline-gold);
        background: linear-gradient(180deg, rgba(163, 127, 62, 0.03) 0%, transparent 100%);
        position: relative;
        margin-block-start: 0.25rem;
      }
      .summary-card::before {
        content: '';
        position: absolute;
        inset-block-start: -1px;
        inset-inline: 40%;
        height: 1.5px;
        background: var(--gold);
        opacity: 0.7;
      }
      .summary-card-title {
        font-family: var(--font-label);
        font-size: 7.5pt;
        font-weight: 600;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--ink-muted);
        text-align: center;
        margin-block-end: 0.45rem;
      }
      html[lang='ar'] .summary-card-title { letter-spacing: 0; text-transform: none; font-size: 9pt; }

      .overall-figures {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        align-items: end;
        justify-items: center;
        padding-block: 0.5rem 0.75rem;
      }
      .overall-tile-label {
        font-family: var(--font-label);
        font-size: 7pt;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--ink-muted);
        margin-block-end: 0.3rem;
      }
      html[lang='ar'] .overall-tile-label { letter-spacing: 0; text-transform: none; font-size: 8.5pt; }
      .overall-tile-value {
        font-family: var(--font-display);
        font-size: 32pt;
        font-weight: 400;
        line-height: 0.95;
        color: var(--accent);
      }
      .overall-tile-value.mono {
        font-family: var(--font-mono);
        font-size: 18pt;
        font-weight: 500;
        letter-spacing: -0.01em;
      }

      .overall-comment {
        margin-block-start: 0.6rem;
        padding-block-start: 0.75rem;
        border-block-start: 0.5px solid var(--hairline);
        font-family: var(--font-body);
        font-size: 10pt;
        font-style: italic;
        color: var(--ink-soft);
        line-height: 1.6;
      }
      html[lang='ar'] .overall-comment { font-style: normal; }
      .overall-comment-label {
        display: block;
        font-family: var(--font-label);
        font-style: normal;
        font-weight: 600;
        font-size: 7pt;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--ink-muted);
        margin-block-end: 0.35rem;
      }
      html[lang='ar'] .overall-comment-label { letter-spacing: 0; text-transform: none; font-size: 9pt; }

      .grading-scale {
        margin-block-start: 1rem;
        padding-block-start: 0.75rem;
        border-block-start: 0.5px solid var(--hairline);
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem 1.25rem;
        font-family: var(--font-label);
        font-size: 7pt;
        font-weight: 500;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--ink-muted);
      }
      .grading-scale-item strong {
        color: var(--accent);
        font-weight: 700;
        margin-inline-end: 0.4em;
      }

      .signature-block {
        margin-block-start: auto;
        padding-block: 1.75rem 0.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .signature-divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        color: var(--gold);
        margin-block-end: 1.25rem;
      }
      .signature-divider::before,
      .signature-divider::after {
        content: '';
        width: 95px;
        height: 0.5px;
        background: currentColor;
      }
      .signature-divider svg { width: 18px; height: 18px; }
      .signature-image {
        max-width: 195px;
        max-height: 60px;
        color: var(--accent);
        margin-block-end: 0.1rem;
      }
      .signature-line {
        width: 200px;
        height: 0.5px;
        background: var(--ink);
      }
      .signature-name {
        font-family: var(--font-display);
        font-size: 13pt;
        color: var(--ink);
        margin-block-start: 0.35rem;
      }
      .signature-title {
        font-family: var(--font-label);
        font-size: 7.5pt;
        font-weight: 500;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: var(--ink-muted);
        margin-block-start: 0.2rem;
      }
      html[lang='ar'] .signature-title { letter-spacing: 0; text-transform: none; font-size: 9pt; }
      .signature-date {
        font-family: var(--font-body);
        font-size: 8.5pt;
        font-style: italic;
        color: var(--ink-light);
        margin-block-start: 0.75rem;
      }
      html[lang='ar'] .signature-date { font-style: normal; }

      .page-footer {
        margin-block-start: 1rem;
        padding-block-start: 0.9rem;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
        font-family: var(--font-label);
        font-size: 7pt;
        font-weight: 500;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--ink-light);
        border-block-start: 0.5px solid var(--hairline);
      }
      html[lang='ar'] .page-footer { letter-spacing: 0; text-transform: none; font-size: 8.5pt; }
      .page-footer .center {
        color: var(--gold);
        font-family: var(--font-display);
        font-size: 11pt;
        text-transform: none;
        letter-spacing: 0.05em;
        font-style: italic;
      }
      .page-footer .end { text-align: end; }
    </style>
  </head>
  <body>
    <article class="page">
      <div class="watermark" aria-hidden="true">
        <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
          <circle cx="200" cy="200" r="184" fill="none" stroke="currentColor" stroke-width="1.6" />
          <circle cx="200" cy="200" r="172" fill="none" stroke="currentColor" stroke-width="0.7" />
          <g transform="translate(200 30)">
            <path d="M0 -9 L2.5 -2.8 L9 -2.8 L3.8 1.1 L5.8 7.5 L0 3.5 L-5.8 7.5 L-3.8 1.1 L-9 -2.8 L-2.5 -2.8 Z" fill="currentColor" />
          </g>
        </svg>
      </div>

      <div class="page-frame"></div>
      <span class="corner-diamond corner-tl"></span>
      <span class="corner-diamond corner-tr"></span>
      <span class="corner-diamond corner-bl"></span>
      <span class="corner-diamond corner-br"></span>

      <div class="page-inner">
        <header class="masthead">
          <div class="masthead-eyebrow">{{eyebrow}}</div>
          <h1 class="masthead-school">{{tenant_name}}</h1>
          <div class="masthead-divider" aria-hidden="true">
            <svg viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 0 L8.6 5.4 L14 7 L8.6 8.6 L7 14 L5.4 8.6 L0 7 L5.4 5.4 Z" fill="currentColor" />
            </svg>
          </div>
          <div class="masthead-title">{{report_title}}</div>
          <div class="masthead-meta">
            <span>{{academic_year}}</span>
            <span class="sep">❦</span>
            <span>{{period_name}}</span>
            <span class="sep">❦</span>
            <span>{{issued_label}} {{issued_date}}</span>
          </div>
          {{#if student.rank_badge_label}}
            <div class="rank-badge">
              <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M8 0 L10 5 L15 6 L11 9 L12 14 L8 11.5 L4 14 L5 9 L1 6 L6 5 Z" fill="currentColor" />
              </svg>
              {{student.rank_badge_label}}
            </div>
          {{/if}}
        </header>

        {{#if student.details.length}}
          <section class="section">
            <div class="section-label">
              <span class="section-label-num">i</span>
              <span class="section-label-text">{{sections.student_label}}</span>
              <span class="section-label-rule"></span>
            </div>
            <div class="student-grid">
              {{#each student.details}}
                <div class="detail-field">
                  <div class="detail-label">{{label}}</div>
                  <div class="detail-value{{#if mono}} mono{{/if}}">{{value}}</div>
                </div>
              {{/each}}
            </div>
          </section>
        {{/if}}

        <section class="section">
          <div class="section-label">
            <span class="section-label-num">ii</span>
            <span class="section-label-text">{{sections.results_label}}</span>
            <span class="section-label-rule"></span>
          </div>
          {{#if has_subjects}}
            <table class="subjects-table">
              <thead>
                <tr>
                  <th>{{headings.subject}}</th>
                  <th class="num">{{headings.mark}}</th>
                  <th class="grade-h">{{headings.grade}}</th>
                  <th class="remark">{{headings.remark}}</th>
                </tr>
              </thead>
              <tbody>
                {{#each subjects}}
                  <tr>
                    <td class="subject-name">{{subject_name}}</td>
                    <td class="subject-mark">{{mark}}</td>
                    <td class="subject-grade">{{grade}}</td>
                    <td class="subject-remark{{#unless remark}} empty{{/unless}}">{{remark}}</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          {{/if}}
        </section>

        <section class="section">
          <div class="section-label">
            <span class="section-label-num">iii</span>
            <span class="section-label-text">{{sections.overall_label}}</span>
            <span class="section-label-rule"></span>
          </div>
          <div class="summary-card">
            <div class="summary-card-title">{{sections.overall_label}}</div>
            <div class="overall-figures">
              <div>
                <div class="overall-tile-label">{{headings.mark}}</div>
                <div class="overall-tile-value mono">{{overall.weighted_average}}</div>
              </div>
              <div>
                <div class="overall-tile-label">{{headings.grade}}</div>
                <div class="overall-tile-value">{{overall.overall_grade}}</div>
              </div>
            </div>
            {{#if overall.has_comment}}
              <div class="overall-comment">
                <span class="overall-comment-label">{{sections.comment_label}}</span>
                {{overall.overall_comment}}
              </div>
            {{/if}}
            {{#if has_grading_scale}}
              <div class="grading-scale">
                {{#each grading_scale}}
                  <span class="grading-scale-item"><strong>{{label}}</strong>{{range}}</span>
                {{/each}}
              </div>
            {{/if}}
          </div>
        </section>

        <div class="signature-block">
          <div class="signature-divider" aria-hidden="true">
            <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 0 L12.5 7.5 L20 10 L12.5 12.5 L10 20 L7.5 12.5 L0 10 L7.5 7.5 Z" fill="currentColor" />
            </svg>
          </div>
          {{#if principal.signature_available}}
            <img class="signature-image" src="{{principal.signature_src}}" alt="" />
          {{else}}
            <div class="signature-line"></div>
          {{/if}}
          {{#if principal.name}}
            <div class="signature-name">{{principal.name}}</div>
          {{/if}}
          <div class="signature-title">{{principal.title_label}}</div>
          <div class="signature-date">{{issued_label}} {{issued_date}}</div>
        </div>

        <footer class="page-footer">
          <span>{{tenant_name}}</span>
          <span class="center">i</span>
          <span class="end">{{report_title}} · {{academic_year}}</span>
        </footer>
      </div>
    </article>
  </body>
</html>
