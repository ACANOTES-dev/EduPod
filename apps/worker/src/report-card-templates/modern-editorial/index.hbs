<!doctype html>
<html lang="{{lang_attr}}" dir="{{direction}}" data-medium="print">
  <head>
    <meta charset="utf-8" />
    <title>{{report_title}} — {{student.full_name}} — {{period_name}}, {{academic_year}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wdth,wght@12..96,75..125,200..800&family=Source+Serif+4:ital,opsz,wght@0,8..60,200..900;1,8..60,200..900&family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Naskh+Arabic:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html { font-size: 16px; }
      html[data-medium='print'] body { background: #fff !important; padding: 0 !important; }
      img { max-width: 100%; display: block; }
      table { border-collapse: collapse; }
      @page { size: A4; margin: 0; }

      :root {
        --paper: #fafaf7;
        --paper-deep: #f3f3ef;
        --paper-warm: #eeeae0;
        --card: #f5f5f2;
        --ink: #0f0f1a;
        --ink-soft: #2e2e38;
        --ink-muted: #56565c;
        --ink-light: #9a9aa0;
        --cobalt: #0b2d82;
        --cobalt-bright: #1a4ad6;
        --cobalt-deep: #08205e;
        --cobalt-pale: #e3e9fb;
        --warm-accent: #d6a93a;
        --hairline: rgba(15, 15, 26, 0.1);
        --hairline-strong: rgba(15, 15, 26, 0.28);
        --hairline-cobalt: rgba(11, 45, 130, 0.22);
        --hairline-cobalt-strong: rgba(11, 45, 130, 0.55);
        --font-display: 'Bricolage Grotesque', 'Noto Naskh Arabic', 'Helvetica Neue', sans-serif;
        --font-body: 'Source Serif 4', 'Noto Naskh Arabic', Georgia, serif;
        --font-label: 'Bricolage Grotesque', 'Noto Naskh Arabic', 'Helvetica Neue', sans-serif;
        --font-mono: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
      }

      html[lang='ar'] {
        --font-display: 'Noto Naskh Arabic', 'Bricolage Grotesque', sans-serif;
        --font-body: 'Noto Naskh Arabic', 'Source Serif 4', Georgia, serif;
        --font-label: 'Noto Naskh Arabic', 'Bricolage Grotesque', sans-serif;
      }

      body {
        font-family: var(--font-body);
        font-weight: 400;
        font-size: 10pt;
        line-height: 1.5;
        color: var(--ink);
        background: var(--paper);
        -webkit-font-smoothing: antialiased;
      }

      .page {
        width: 210mm;
        height: 297mm;
        padding: 20mm 20mm 14mm;
        background: var(--paper);
        position: relative;
        overflow: hidden;
        page-break-after: always;
      }
      .page:last-of-type { page-break-after: auto; }
      .page::before {
        content: '';
        position: absolute;
        inset-block: 22mm 16mm;
        inset-inline-start: 14mm;
        width: 2px;
        background: var(--cobalt);
        z-index: 1;
      }

      .page-watermark {
        position: absolute;
        inset-block-end: 18mm;
        inset-inline-end: 0;
        font-family: var(--font-display);
        font-variation-settings: 'wdth' 75, 'wght' 800, 'opsz' 96;
        font-size: 180pt;
        line-height: 0.8;
        color: transparent;
        -webkit-text-stroke: 1px var(--hairline-cobalt);
        letter-spacing: -0.04em;
        pointer-events: none;
        z-index: 0;
        white-space: nowrap;
        opacity: 0.45;
      }

      .page-inner {
        position: relative;
        z-index: 2;
        height: calc(297mm - 34mm);
        display: flex;
        flex-direction: column;
        padding-inline-start: 10mm;
      }

      .masthead {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 2rem;
        align-items: start;
        padding-block-end: 1.4rem;
        margin-block-end: 1.75rem;
        border-block-end: 1px solid var(--ink);
      }
      .masthead-main { display: flex; flex-direction: column; }

      .masthead-eyebrow {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 600;
        font-size: 8pt;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--cobalt);
        margin-block-end: 0.9rem;
      }
      html[lang='ar'] .masthead-eyebrow { letter-spacing: 0; text-transform: none; font-size: 10pt; }
      .masthead-eyebrow::before {
        content: '';
        width: 18px;
        height: 2px;
        background: var(--cobalt);
      }

      .masthead-school {
        font-family: var(--font-display);
        font-variation-settings: 'wdth' 85, 'wght' 700, 'opsz' 96;
        font-size: 34pt;
        line-height: 1.02;
        color: var(--ink);
        letter-spacing: -0.022em;
        margin-block-end: 0.9rem;
      }
      html[lang='ar'] .masthead-school { line-height: 1.25; letter-spacing: 0; }

      .masthead-meta-row {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding-block-start: 0.55rem;
        border-block-start: 0.5px solid var(--hairline);
      }
      .masthead-meta-item { display: flex; flex-direction: column; gap: 0.1rem; }
      .masthead-meta-item + .masthead-meta-item {
        padding-inline-start: 1.25rem;
        border-inline-start: 0.5px solid var(--hairline);
      }
      .masthead-meta-label {
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 500;
        font-size: 6.5pt;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--ink-muted);
      }
      html[lang='ar'] .masthead-meta-label { letter-spacing: 0; text-transform: none; font-size: 8.5pt; }
      .masthead-meta-value {
        font-family: var(--font-body);
        font-size: 10pt;
        color: var(--ink);
      }

      .masthead-aside {
        display: flex;
        flex-direction: column;
        align-items: end;
        gap: 0.6rem;
      }
      .rank-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.3rem 0.7rem;
        background: var(--cobalt);
        color: #fff;
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 700;
        font-size: 7.5pt;
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }
      html[lang='ar'] .rank-badge { letter-spacing: 0; text-transform: none; font-size: 9pt; }
      .rank-badge svg { width: 10px; height: 10px; }
      .masthead-doc-id {
        font-family: var(--font-mono);
        font-size: 6.5pt;
        color: var(--ink-muted);
        letter-spacing: 0.05em;
        text-align: end;
      }

      .section { margin-block-end: 1.5rem; }
      .section-label {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        margin-block-end: 0.9rem;
      }
      .section-label-num {
        font-family: var(--font-display);
        font-variation-settings: 'wdth' 125, 'wght' 800, 'opsz' 96;
        font-size: 20pt;
        line-height: 0.9;
        color: transparent;
        -webkit-text-stroke: 1.1px var(--cobalt);
        letter-spacing: -0.02em;
      }
      .section-label-text {
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 600;
        font-size: 9pt;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--ink);
      }
      html[lang='ar'] .section-label-text { letter-spacing: 0; text-transform: none; font-size: 11pt; }
      .section-label-rule {
        flex: 1;
        height: 1px;
        background: var(--ink);
      }

      .student-strip {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        background: var(--card);
        border-block: 1px solid var(--ink);
      }
      .detail-cell {
        padding: 0.85rem 1rem;
        border-inline-end: 0.5px solid var(--hairline-strong);
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }
      .detail-cell:nth-child(3n) { border-inline-end: none; }
      .detail-cell:nth-child(n + 4) { border-block-start: 0.5px solid var(--hairline-strong); }
      .detail-label {
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 500;
        font-size: 6.5pt;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--ink-muted);
      }
      html[lang='ar'] .detail-label { letter-spacing: 0; text-transform: none; font-size: 8.5pt; }
      .detail-value {
        font-family: var(--font-body);
        font-size: 10.5pt;
        font-weight: 500;
        color: var(--ink);
      }
      .detail-value.mono {
        font-family: var(--font-mono);
        font-size: 9pt;
      }

      .subjects-table { width: 100%; }
      .subjects-table thead th {
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 600;
        font-size: 6.5pt;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--ink-muted);
        text-align: start;
        padding: 0.5rem 0.5rem 0.45rem;
        border-block-end: 1px solid var(--ink);
      }
      html[lang='ar'] .subjects-table thead th { letter-spacing: 0; text-transform: none; font-size: 9pt; }
      .subjects-table thead th.mark-col { text-align: end; width: 12%; }
      .subjects-table thead th.grade-col { text-align: center; width: 9%; }
      .subjects-table thead th.remark-col { width: 48%; }
      .subjects-table tbody td {
        padding: 0.6rem 0.5rem;
        border-block-end: 0.5px solid var(--hairline);
        vertical-align: top;
      }
      .subjects-table tbody tr:last-child td { border-block-end: 1px solid var(--ink); }
      .subject-name {
        font-family: var(--font-body);
        font-size: 11pt;
        font-weight: 600;
        color: var(--ink);
      }
      .subject-mark {
        font-family: var(--font-mono);
        font-size: 11pt;
        font-weight: 500;
        color: var(--ink);
        text-align: end;
        font-variant-numeric: tabular-nums;
      }
      .subject-grade-cell { text-align: center; }
      .grade-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 30px;
        padding: 0.18rem 0.5rem;
        background: var(--cobalt);
        color: #fff;
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 700;
        font-size: 9pt;
        letter-spacing: 0.04em;
        border-radius: 2px;
      }
      .grade-pill.b { background: var(--cobalt-bright); }
      .grade-pill.c { background: var(--ink-muted); }
      .grade-pill.d { background: var(--ink-light); }
      .grade-pill.f { background: #8a3030; }
      .grade-pill.empty {
        background: transparent;
        color: var(--ink-light);
        border: 1px dashed var(--ink-light);
      }
      .subject-remark {
        font-family: var(--font-body);
        font-size: 9pt;
        font-style: italic;
        color: var(--ink-soft);
        line-height: 1.5;
      }
      html[lang='ar'] .subject-remark { font-style: normal; }
      .subject-remark.empty { color: var(--ink-light); }

      .summary-grid {
        display: grid;
        grid-template-columns: 1.35fr 1fr;
        gap: 1.5rem;
      }
      .summary-grid.single { grid-template-columns: 1fr; }

      .summary-panel {
        padding: 1rem 1.15rem 1.15rem;
        background: var(--card);
        border: 1px solid var(--ink);
        display: flex;
        flex-direction: column;
      }
      .summary-panel-title {
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 600;
        font-size: 7.5pt;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--ink);
        margin-block-end: 0.55rem;
      }
      html[lang='ar'] .summary-panel-title { letter-spacing: 0; text-transform: none; font-size: 9.5pt; }
      .comment-body {
        font-family: var(--font-body);
        font-size: 10pt;
        font-style: italic;
        color: var(--ink-soft);
        line-height: 1.55;
      }
      html[lang='ar'] .comment-body { font-style: normal; }
      .comment-body.empty { color: var(--ink-light); }

      .final-card {
        padding: 1rem 1.25rem 1.25rem;
        background: var(--cobalt);
        color: #fff;
        display: flex;
        flex-direction: column;
        position: relative;
      }
      .final-card::before {
        content: '';
        position: absolute;
        inset-block-start: 0;
        inset-inline-end: 0;
        width: 40%;
        height: 6px;
        background: var(--warm-accent);
      }
      .final-card-title {
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 600;
        font-size: 7.5pt;
        letter-spacing: 0.26em;
        text-transform: uppercase;
        opacity: 0.8;
        margin-block-end: 0.5rem;
      }
      html[lang='ar'] .final-card-title { letter-spacing: 0; text-transform: none; font-size: 9.5pt; }
      .final-card-grade {
        font-family: var(--font-display);
        font-variation-settings: 'wdth' 75, 'wght' 800, 'opsz' 96;
        font-size: 72pt;
        line-height: 0.88;
        letter-spacing: -0.04em;
        margin-block: 0.15rem 0.5rem;
      }
      .final-card-score {
        font-family: var(--font-mono);
        font-size: 18pt;
        font-weight: 500;
        letter-spacing: -0.01em;
        font-variant-numeric: tabular-nums;
        margin-block-end: 0.9rem;
      }
      .final-card-footnote {
        padding-block-start: 0.75rem;
        border-block-start: 0.5px solid rgba(255, 255, 255, 0.3);
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 500;
        font-size: 6.5pt;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        opacity: 0.85;
      }
      html[lang='ar'] .final-card-footnote { letter-spacing: 0; text-transform: none; font-size: 8.5pt; }

      .grading-scale {
        margin-block-start: 1rem;
        padding-block-start: 0.75rem;
        border-block-start: 1px solid var(--hairline);
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem 1.1rem;
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 500;
        font-size: 6.5pt;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink-muted);
      }
      .grading-scale-item strong {
        color: var(--cobalt);
        font-weight: 700;
        margin-inline-end: 0.4em;
      }

      .signature-block {
        margin-block-start: auto;
        padding-block: 1.75rem 0.5rem;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: end;
        gap: 2rem;
      }
      .sig-left { display: flex; flex-direction: column; gap: 0.3rem; }
      .sig-left-label {
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 500;
        font-size: 6.5pt;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--ink-muted);
      }
      html[lang='ar'] .sig-left-label { letter-spacing: 0; text-transform: none; font-size: 8.5pt; }
      .sig-left-date {
        font-family: var(--font-mono);
        font-size: 10pt;
        color: var(--ink);
      }
      .signature-stack {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
      }
      .signature-image {
        max-width: 180px;
        max-height: 54px;
        color: var(--cobalt);
      }
      .signature-line {
        width: 220px;
        height: 1px;
        background: var(--ink);
      }
      .signature-name {
        font-family: var(--font-display);
        font-variation-settings: 'wdth' 100, 'wght' 600;
        font-size: 13pt;
        color: var(--ink);
        margin-block-start: 0.4rem;
      }
      .signature-title {
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 500;
        font-size: 7pt;
        letter-spacing: 0.26em;
        text-transform: uppercase;
        color: var(--ink-muted);
      }
      html[lang='ar'] .signature-title { letter-spacing: 0; text-transform: none; font-size: 9pt; }
      .sig-right {
        text-align: end;
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 500;
        font-size: 6.5pt;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--ink-muted);
      }
      html[lang='ar'] .sig-right { letter-spacing: 0; text-transform: none; font-size: 8.5pt; }

      .page-footer {
        margin-block-start: 1rem;
        padding-block-start: 0.9rem;
        border-block-start: 1px solid var(--ink);
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
        font-family: var(--font-label);
        font-variation-settings: 'wdth' 100, 'wght' 500;
        font-size: 6.5pt;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--ink-muted);
      }
      html[lang='ar'] .page-footer { letter-spacing: 0; text-transform: none; font-size: 8.5pt; }
      .page-footer .end { text-align: end; }
      .page-number {
        font-family: var(--font-display);
        font-variation-settings: 'wdth' 125, 'wght' 800, 'opsz' 96;
        font-size: 16pt;
        color: var(--cobalt);
        letter-spacing: -0.02em;
        line-height: 1;
      }
    </style>
  </head>
  <body>
    <article class="page">
      <div class="page-watermark" aria-hidden="true">{{academic_year}}</div>

      <div class="page-inner">
        <header class="masthead">
          <div class="masthead-main">
            <div class="masthead-eyebrow">{{eyebrow}} · {{issued_label}} {{issued_date}}</div>
            <h1 class="masthead-school">{{tenant_name}}</h1>
            <div class="masthead-meta-row">
              <div class="masthead-meta-item">
                <div class="masthead-meta-label">{{sections.results_label}}</div>
                <div class="masthead-meta-value">{{academic_year}}</div>
              </div>
              <div class="masthead-meta-item">
                <div class="masthead-meta-label">{{headings.mark}}</div>
                <div class="masthead-meta-value">{{period_name}}</div>
              </div>
              <div class="masthead-meta-item">
                <div class="masthead-meta-label">{{headings.grade}}</div>
                <div class="masthead-meta-value">{{overall.overall_grade}}</div>
              </div>
            </div>
          </div>
          <div class="masthead-aside">
            {{#if student.rank_badge_label}}
              <div class="rank-badge">
                <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M8 0 L10 5 L15 6 L11 9 L12 14 L8 11.5 L4 14 L5 9 L1 6 L6 5 Z" fill="currentColor" />
                </svg>
                {{student.rank_badge_label}}
              </div>
            {{/if}}
            <div class="masthead-doc-id">{{student.full_name}}</div>
          </div>
        </header>

        {{#if student.details.length}}
          <section class="section">
            <div class="section-label">
              <span class="section-label-num">01.</span>
              <span class="section-label-text">{{sections.student_label}}</span>
              <span class="section-label-rule"></span>
            </div>
            <div class="student-strip">
              {{#each student.details}}
                <div class="detail-cell">
                  <div class="detail-label">{{label}}</div>
                  <div class="detail-value{{#if mono}} mono{{/if}}">{{value}}</div>
                </div>
              {{/each}}
            </div>
          </section>
        {{/if}}

        <section class="section">
          <div class="section-label">
            <span class="section-label-num">02.</span>
            <span class="section-label-text">{{sections.results_label}}</span>
            <span class="section-label-rule"></span>
          </div>
          {{#if has_subjects}}
            <table class="subjects-table">
              <thead>
                <tr>
                  <th>{{headings.subject}}</th>
                  <th class="mark-col">{{headings.mark}}</th>
                  <th class="grade-col">{{headings.grade}}</th>
                  <th class="remark-col">{{headings.remark}}</th>
                </tr>
              </thead>
              <tbody>
                {{#each subjects}}
                  <tr>
                    <td class="subject-name">{{subject_name}}</td>
                    <td class="subject-mark">{{mark}}</td>
                    <td class="subject-grade-cell">
                      <span class="grade-pill {{grade_class}}">{{grade}}</span>
                    </td>
                    <td class="subject-remark{{#unless remark}} empty{{/unless}}">{{remark}}</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          {{/if}}
        </section>

        <section class="section">
          <div class="section-label">
            <span class="section-label-num">03.</span>
            <span class="section-label-text">{{sections.overall_label}}</span>
            <span class="section-label-rule"></span>
          </div>
          <div class="summary-grid{{#unless overall.has_comment}} single{{/unless}}">
            {{#if overall.has_comment}}
              <div class="summary-panel">
                <div class="summary-panel-title">{{sections.comment_label}}</div>
                <div class="comment-body">{{overall.overall_comment}}</div>
              </div>
            {{/if}}
            <div class="final-card">
              <div class="final-card-title">{{sections.overall_label}}</div>
              <div class="final-card-grade">{{overall.overall_grade}}</div>
              <div class="final-card-score">{{overall.weighted_average}}</div>
              <div class="final-card-footnote">{{period_name}} · {{academic_year}}</div>
            </div>
          </div>
          {{#if has_grading_scale}}
            <div class="grading-scale">
              {{#each grading_scale}}
                <span class="grading-scale-item"><strong>{{label}}</strong>{{range}}</span>
              {{/each}}
            </div>
          {{/if}}
        </section>

        <div class="signature-block">
          <div class="sig-left">
            <div class="sig-left-label">{{issued_label}}</div>
            <div class="sig-left-date">{{issued_date}}</div>
          </div>
          <div class="signature-stack">
            {{#if principal.signature_available}}
              <img class="signature-image" src="{{principal.signature_src}}" alt="" />
            {{else}}
              <div class="signature-line"></div>
            {{/if}}
            {{#if principal.name}}
              <div class="signature-name">{{principal.name}}</div>
            {{/if}}
            <div class="signature-title">{{principal.title_label}}</div>
          </div>
          <div class="sig-right">{{tenant_name}}</div>
        </div>

        <footer class="page-footer">
          <span>{{tenant_name}}</span>
          <span class="page-number">01</span>
          <span class="end">{{report_title}} · {{academic_year}}</span>
        </footer>
      </div>
    </article>
  </body>
</html>
