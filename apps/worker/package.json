{
  "name": "@school/worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/apps/worker/src/main",
    "start:prod": "node dist/apps/worker/src/main",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "test:changed": "jest --changedSince=main --passWithNoTests",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.1.0",
    "@school/prisma": "workspace:*",
    "@school/shared": "workspace:*",
    "bullmq": "^5.31.0",
    "dotenv": "^17.3.1",
    "handlebars": "^4.7.9",
    "ioredis": "^5.4.2",
    "puppeteer": "^23.11.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.1.0",
    "rxjs": "^7.8.1",
    "twilio": "^5.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@school/eslint-config": "workspace:*",
    "@school/tsconfig": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "eslint": "^8.57.0",
    "eslint-plugin-school": "workspace:*",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  }
}
