{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "lint:ci": {},
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": [
        "tsconfig.tsbuildinfo",
        "dist/tsconfig.tsbuildinfo",
        "dist/tsconfig.build.tsbuildinfo",
        ".next/cache/**"
      ]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:changed": {
      "dependsOn": ["^build"]
    }
  }
}
