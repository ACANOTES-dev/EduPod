# ============================================================
# School Operating System — Local Development Environment
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to Git.
# ============================================================

# ============================================================
# DATABASE (Phase 0)
# ============================================================
DATABASE_URL=postgresql://postgres:localpassword@localhost:5553/school_platform

# ============================================================
# REDIS (Phase 0)
# ============================================================
REDIS_URL=redis://localhost:5554

# ============================================================
# AUTH (Phase 1)
# ============================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=<generate-with-openssl-rand-hex-32>
JWT_REFRESH_SECRET=<generate-with-openssl-rand-hex-32>

# ============================================================
# SEARCH (Phase 2)
# ============================================================
MEILISEARCH_HOST=http://localhost:5555
MEILISEARCH_API_KEY=local-dev-master-key

# ============================================================
# ENCRYPTION — Local Dev Fallback (Phase 6)
# Skips AWS Secrets Manager, uses this key directly for
# encrypting Stripe keys and staff bank details locally.
# ============================================================
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY_LOCAL=<generate-with-openssl-rand-hex-32>

# ============================================================
# STRIPE — Test Mode (Phase 6)
# Each school enters their own keys in the admin UI.
# These are for YOUR development/testing only.
# ============================================================
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# EMAIL — Resend (Phase 7)
# ============================================================
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...
RESEND_FROM_EMAIL=noreply@yourplatform.com

# ============================================================
# WHATSAPP — Twilio (Phase 7)
# ============================================================
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ============================================================
# AWS — Local Dev (Phase 6+ if using real S3/Secrets Manager)
# ============================================================
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=school-platform-dev

# ============================================================
# CLOUDFLARE (Production only — not needed locally)
# ============================================================
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ZONE_ID=...
# CLOUDFLARE_ACCOUNT_ID=...

# ============================================================
# MONITORING (Production only — optional for local dev)
# ============================================================
# SENTRY_DSN_BACKEND=https://...@sentry.io/...
# SENTRY_DSN_FRONTEND=https://...@sentry.io/...
# SENTRY_AUTH_TOKEN=...
# SENTRY_ORG=your-org
# SENTRY_PROJECT_BACKEND=school-api
# SENTRY_PROJECT_FRONTEND=school-web

# ============================================================
# APP
# ============================================================
NODE_ENV=development
APP_URL=http://localhost:5551
API_URL=http://localhost:5552
# NEXT_PUBLIC_API_URL should be empty in production (client-side calls use relative paths via Next.js rewrites).
# Only set for local dev if not using the Next.js rewrite proxy.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SENTRY_DSN=
