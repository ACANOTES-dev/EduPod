model PastoralConcern {
  id                      String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id               String                  @db.Uuid
  student_id              String                  @db.Uuid
  logged_by_user_id       String                  @db.Uuid
  author_masked           Boolean                 @default(false)
  category                String                  @db.VarChar(50)
  severity                PastoralConcernSeverity
  tier                    Int                     @default(1) @db.SmallInt
  occurred_at             DateTime                @db.Timestamptz()
  location                String?                 @db.VarChar(255)
  witnesses               Json?
  actions_taken           String?                 @db.Text
  follow_up_needed        Boolean                 @default(false)
  follow_up_suggestion    String?                 @db.Text
  case_id                 String?                 @db.Uuid
  behaviour_incident_id   String?                 @db.Uuid
  parent_shareable        Boolean                 @default(false)
  parent_share_level      String?                 @default("category_only") @db.VarChar(20)
  shared_by_user_id       String?                 @db.Uuid
  shared_at               DateTime?               @db.Timestamptz()
  legal_hold              Boolean                 @default(false)
  imported                Boolean                 @default(false)
  import_hash             String?                 @db.Text
  acknowledged_at         DateTime?               @db.Timestamptz()
  acknowledged_by_user_id String?                 @db.Uuid
  created_at              DateTime                @default(now()) @db.Timestamptz()
  updated_at              DateTime                @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant               Tenant                           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  student              Student                          @relation("pc_concern_student", fields: [student_id], references: [id], onDelete: Restrict)
  logged_by            User                             @relation("pc_concern_logged_by", fields: [logged_by_user_id], references: [id], onDelete: Restrict)
  case                 PastoralCase?                    @relation(fields: [case_id], references: [id], onDelete: SetNull)
  behaviour_incident   BehaviourIncident?               @relation("pc_concern_behaviour_incident", fields: [behaviour_incident_id], references: [id], onDelete: SetNull)
  shared_by            User?                            @relation("pc_concern_shared_by", fields: [shared_by_user_id], references: [id], onDelete: SetNull)
  acknowledged_by      User?                            @relation("pc_concern_acknowledged_by", fields: [acknowledged_by_user_id], references: [id], onDelete: SetNull)
  involved_students    PastoralConcernInvolvedStudent[]
  versions             PastoralConcernVersion[]
  cp_records           CpRecord[]
  parent_contacts      PastoralParentContact[]          @relation("pc_parent_contact_concern")
  sst_agenda_items     SstMeetingAgendaItem[]           @relation("pc_sst_agenda_concern")
  student_checkins     StudentCheckin[]                 @relation("pc_checkin_auto_concern")
  safeguardingConcerns SafeguardingConcern[]

  @@index([tenant_id, student_id, created_at(sort: Desc)], map: "idx_pastoral_concerns_tenant_student_created")
  @@index([tenant_id, tier, created_at(sort: Desc)], map: "idx_pastoral_concerns_tenant_tier_created")
  @@index([tenant_id, case_id], map: "idx_pastoral_concerns_tenant_case")
  @@index([tenant_id, severity, acknowledged_at], map: "idx_pastoral_concerns_tenant_severity_ack")
  @@index([tenant_id, import_hash], map: "idx_pastoral_concerns_import_hash")
  @@map("pastoral_concerns")
}

