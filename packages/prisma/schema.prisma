model TenantDomain {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String             @db.Uuid
  domain              String             @unique @db.VarChar(255)
  domain_type         DomainType
  verification_status VerificationStatus @default(pending)
  ssl_status          SslStatus          @default(pending)
  is_primary          Boolean            @default(false)
  created_at          DateTime           @default(now()) @db.Timestamptz()
  updated_at          DateTime           @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([domain], name: "idx_tenant_domains_domain")
  @@index([tenant_id], name: "idx_tenant_domains_tenant")
  @@map("tenant_domains")
}

model TenantModule {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String  @db.Uuid
  module_key String  @db.VarChar(100)
  is_enabled Boolean

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, module_key], name: "idx_tenant_modules_tenant_module")
  @@index([tenant_id], name: "idx_tenant_modules_tenant")
  @@map("tenant_modules")
}

model TenantBranding {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String   @unique @db.Uuid
  primary_color       String?  @db.VarChar(20)
  secondary_color     String?  @db.VarChar(20)
  logo_url            String?  @db.Text
  school_name_display String?  @db.VarChar(255)
  school_name_ar      String?  @db.VarChar(255)
  email_from_name     String?  @db.VarChar(255)
  email_from_name_ar  String?  @db.VarChar(255)
  support_email       String?  @db.VarChar(255)
  support_phone       String?  @db.VarChar(50)
  receipt_prefix      String   @default("REC") @db.VarChar(30)
  invoice_prefix      String   @default("INV") @db.VarChar(30)
  report_card_title   String?  @db.VarChar(255)
  payslip_prefix      String   @default("PSL") @db.VarChar(30)
  created_at          DateTime @default(now()) @db.Timestamptz()
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("tenant_branding")
}

model TenantSetting {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @unique @db.Uuid
  settings   Json     @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

