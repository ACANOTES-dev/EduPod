model BehaviourCategory {
  id                           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                    String            @db.Uuid
  name                         String            @db.VarChar(100)
  name_ar                      String?           @db.VarChar(100)
  polarity                     BehaviourPolarity
  severity                     Int
  point_value                  Int               @default(0)
  color                        String?           @db.VarChar(7)
  icon                         String?           @db.VarChar(50)
  requires_follow_up           Boolean           @default(false)
  requires_parent_notification Boolean           @default(false)
  parent_visible               Boolean           @default(true)
  benchmark_category           BenchmarkCategory
  display_order                Int               @default(0)
  is_active                    Boolean           @default(true)
  is_system                    Boolean           @default(false)
  created_at                   DateTime          @default(now()) @db.Timestamptz()
  updated_at                   DateTime          @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant                Tenant                         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  incidents             BehaviourIncident[]
  description_templates BehaviourDescriptionTemplate[]

  @@unique([tenant_id, name], name: "idx_behaviour_categories_tenant_name")
  @@index([tenant_id], name: "idx_behaviour_categories_tenant")
  @@map("behaviour_categories")
}

model BehaviourIncident {
  id                           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                    String                 @db.Uuid
  incident_number              String                 @db.VarChar(20)
  idempotency_key              String?                @db.VarChar(36)
  category_id                  String                 @db.Uuid
  polarity                     BehaviourPolarity
  severity                     Int
  reported_by_id               String                 @db.Uuid
  description                  String                 @db.Text
  parent_description           String?                @db.Text
  parent_description_ar        String?                @db.Text
  parent_description_locked    Boolean                @default(false)
  parent_description_set_by_id String?                @db.Uuid
  parent_description_set_at    DateTime?              @db.Timestamptz()
  context_notes                String?                @db.Text
  location                     String?                @db.VarChar(100)
  context_type                 ContextType            @default(class_)
  occurred_at                  DateTime               @db.Timestamptz()
  logged_at                    DateTime               @default(now()) @db.Timestamptz()
  academic_year_id             String                 @db.Uuid
  academic_period_id           String?                @db.Uuid
  schedule_entry_id            String?                @db.Uuid
  subject_id                   String?                @db.Uuid
  room_id                      String?                @db.Uuid
  period_order                 Int?
  weekday                      Int?
  status                       IncidentStatus         @default(draft)
  approval_status              IncidentApprovalStatus @default(not_required)
  approval_request_id          String?                @db.Uuid
  parent_notification_status   ParentNotifStatus      @default(not_required)
  follow_up_required           Boolean                @default(false)
  escalated_from_id            String?                @db.Uuid
  policy_evaluation_id         String?                @db.Uuid
  context_snapshot             Json                   @default("{}")
  retention_status             RetentionStatus        @default(active)
  archived_at                  DateTime?              @db.Timestamptz()
  created_at                   DateTime               @default(now()) @db.Timestamptz()
  updated_at                   DateTime               @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant                         Tenant                           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  category                       BehaviourCategory                @relation(fields: [category_id], references: [id])
  reported_by                    User                             @relation("bh_incident_reporter", fields: [reported_by_id], references: [id], onDelete: Restrict)
  parent_description_set_by      User?                            @relation("bh_parent_desc_setter", fields: [parent_description_set_by_id], references: [id], onDelete: SetNull)
  academic_year                  AcademicYear                     @relation("bh_incident_academic_year", fields: [academic_year_id], references: [id])
  academic_period                AcademicPeriod?                  @relation("bh_incident_academic_period", fields: [academic_period_id], references: [id], onDelete: SetNull)
  schedule_entry                 Schedule?                        @relation("bh_incident_schedule", fields: [schedule_entry_id], references: [id], onDelete: SetNull)
  subject                        Subject?                         @relation("bh_incident_subject", fields: [subject_id], references: [id], onDelete: SetNull)
  room                           Room?                            @relation("bh_incident_room", fields: [room_id], references: [id], onDelete: SetNull)
  approval_request               ApprovalRequest?                 @relation("bh_incident_approval", fields: [approval_request_id], references: [id], onDelete: SetNull)
  escalated_from                 BehaviourIncident?               @relation("bh_incident_escalation", fields: [escalated_from_id], references: [id], onDelete: SetNull)
  escalated_to                   BehaviourIncident[]              @relation("bh_incident_escalation")
  participants                   BehaviourIncidentParticipant[]
  sanctions                      BehaviourSanction[]
  appeals                        BehaviourAppeal[]
  parent_acknowledgements        BehaviourParentAcknowledgement[]
  exclusion_cases                BehaviourExclusionCase[]
  intervention_incidents         BehaviourInterventionIncident[]
  policy_evaluations             BehaviourPolicyEvaluation[]
  recognition_awards             BehaviourRecognitionAward[]      @relation("bh_award_trigger_incident")
  safeguarding_concern_incidents SafeguardingConcernIncident[]
  pastoral_concerns              PastoralConcern[]                @relation("pc_concern_behaviour_incident")

