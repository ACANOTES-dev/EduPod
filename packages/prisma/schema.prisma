generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext, btree_gist]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantStatus {
  active
  suspended
  archived
}

enum DomainType {
  app
  public_site
}

enum VerificationStatus {
  pending
  verified
  failed
}

enum SslStatus {
  pending
  active
  failed
}

enum UserGlobalStatus {
  active
  suspended
  disabled
}

enum MembershipStatus {
  invited
  pending_verification
  active
  suspended
  disabled
  archived
}

enum RoleTier {
  platform
  admin
  staff
  parent
}

enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

enum ApprovalActionType {
  announcement_publish
  invoice_issue
  application_accept
  payment_refund
  payroll_finalise
}

enum ApprovalRequestStatus {
  pending_approval
  approved
  rejected
  executed
  cancelled
  expired
}

// ─── P6B Enums ──────────────────────────────────────────────────────────────

enum CompensationType {
  salaried
  per_class
}

enum PayrollRunStatus {
  draft
  pending_approval
  finalised
  cancelled
}

// ─── P2 Enums ──────────────────────────────────────────────────────────────

enum HouseholdStatus {
  active
  inactive
  archived
}

enum ParentStatus {
  active
  inactive
}

enum StudentStatus {
  applicant
  active
  withdrawn
  graduated
  archived
}

enum Gender {
  male
  female
  other
  prefer_not_to_say
}

enum AcademicYearStatus {
  planned
  active
  closed
}

enum AcademicPeriodStatus {
  planned
  active
  closed
}

enum AcademicPeriodType {
  term
  semester
  quarter
  custom
}

enum SubjectType {
  academic
  supervision
  duty
  other
}

enum ClassStatus {
  active
  inactive
  archived
}

enum ClassStaffRole {
  teacher
  assistant
  homeroom
  substitute
}

enum EmploymentStatus {
  active
  inactive
}

enum EmploymentType {
  full_time
  part_time
  contract
  substitute
}

enum ClassEnrolmentStatus {
  active
  dropped
  completed
}

// ─── P4A Enums ────────────────────────────────────────────────────────────

enum RoomType {
  classroom
  lab
  gym
  auditorium
  library
  computer_lab
  art_room
  music_room
  outdoor
  other
}

enum ScheduleSource {
  manual
  auto_generated
  pinned
}

enum ClosureScope {
  all
  year_group
  class
}

enum AttendanceSessionStatus {
  open
  submitted
  locked
  cancelled
}

enum AttendanceRecordStatus {
  present
  absent_unexcused
  absent_excused
  late
  left_early
}

enum DailyAttendanceStatus {
  present
  partially_absent
  absent
  late
  excused
}

// ─── P4B Enums ──────────────────────────────────────────────────────────────

enum SchedulePeriodType {
  teaching
  break_supervision
  assembly
  lunch_duty
  free
}

enum SpreadPreference {
  spread_evenly
  cluster
  no_preference
}

enum SchedulingPreferenceType {
  subject
  class_pref
  time_slot
}

enum SchedulingPreferencePriority {
  low
  medium
  high
}

enum SchedulingRunMode {
  auto
  hybrid
}

enum SchedulingRunStatus {
  queued
  running
  completed
  failed
  applied
  discarded
}

enum SupervisionMode {
  none
  yard
  classroom_previous
  classroom_next
}

// ─── P3 Enums ──────────────────────────────────────────────────────────────

enum FormDefinitionStatus {
  draft
  published
  archived
}

enum ApplicationFieldType {
  short_text
  long_text
  number
  date
  boolean
  single_select
  multi_select
  phone
  email
  country
  yes_no
}

enum ApplicationStatus {
  draft
  submitted
  under_review
  pending_acceptance_approval
  accepted
  rejected
  withdrawn
}

// ─── P7 Enums ──────────────────────────────────────────────────────────────

enum AnnouncementStatus {
  draft
  pending_approval
  scheduled
  published
  archived
}

enum AnnouncementScope {
  school
  year_group
  class
  household
  custom
}

enum NotificationChannel {
  email
  whatsapp
  in_app
}

enum NotificationStatus {
  queued
  sent
  delivered
  failed
  read
}

enum ParentInquiryStatus {
  open
  in_progress
  closed
}

enum InquiryAuthorType {
  parent
  admin
}

enum WebsitePageType {
  home
  about
  admissions
  contact
  custom
}

enum WebsitePageStatus {
  draft
  published
  unpublished
}

enum ContactFormStatus {
  new_submission @map("new")
  reviewed
  closed
  spam
}

// ─── Platform & Tenancy ──────────────────────────────────────────────────────

model Tenant {
  id                        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                      String       @db.VarChar(255)
  slug                      String       @unique @db.VarChar(100)
  status                    TenantStatus @default(active)
  default_locale            String       @default("en") @db.VarChar(10)
  timezone                  String       @db.VarChar(100)
  date_format               String       @db.VarChar(50)
  currency_code             String       @db.VarChar(10)
  academic_year_start_month Int          @db.SmallInt
  created_at                DateTime     @default(now()) @db.Timestamptz()
  updated_at                DateTime     @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  domains               TenantDomain[]
  modules               TenantModule[]
  branding              TenantBranding?
  settings              TenantSetting?
  notification_settings TenantNotificationSetting[]
  sequences             TenantSequence[]
  stripe_config         TenantStripeConfig?
  memberships           TenantMembership[]
  roles                 Role[]
  role_permissions      RolePermission[]
  membership_roles      MembershipRole[]
  invitations           Invitation[]
  approval_workflows    ApprovalWorkflow[]
  approval_requests     ApprovalRequest[]
  user_ui_preferences   UserUiPreference[]

  // P2 Relations
  households                   Household[]
  household_emergency_contacts HouseholdEmergencyContact[]
  parents                      Parent[]
  household_parents            HouseholdParent[]
  students                     Student[]
  student_parents              StudentParent[]
  staff_profiles               StaffProfile[]
  academic_years               AcademicYear[]
  academic_periods             AcademicPeriod[]
  year_groups                  YearGroup[]
  subjects                     Subject[]
  classes                      Class[]
  class_staff                  ClassStaff[]
  class_enrolments             ClassEnrolment[]

  // P3 Relations
  admission_form_definitions AdmissionFormDefinition[]
  admission_form_fields      AdmissionFormField[]
  applications               Application[]
  application_notes          ApplicationNote[]

  // P4A Relations
  rooms                      Room[]
  schedules                  Schedule[]
  school_closures            SchoolClosure[]
  attendance_sessions        AttendanceSession[]
  attendance_records         AttendanceRecord[]
  daily_attendance_summaries DailyAttendanceSummary[]

  // P4B Relations
  schedule_period_templates     SchedulePeriodTemplate[]
  class_scheduling_requirements ClassSchedulingRequirement[]
  staff_availability            StaffAvailability[]
  staff_scheduling_preferences  StaffSchedulingPreference[]
  scheduling_runs               SchedulingRun[]

  // P4B-v2 Relations
  curriculum_requirements    CurriculumRequirement[]
  teacher_competencies       TeacherCompetency[]
  break_groups               BreakGroup[]
  break_group_year_groups    BreakGroupYearGroup[]
  room_closures              RoomClosure[]
  teacher_scheduling_configs TeacherSchedulingConfig[]

  // P5 Relations
  grading_scales              GradingScale[]
  assessment_categories       AssessmentCategory[]
  class_subject_grade_configs ClassSubjectGradeConfig[]
  assessments                 Assessment[]
  grades                      Grade[]
  period_grade_snapshots      PeriodGradeSnapshot[]
  report_cards                ReportCard[]

  // P6 Relations
  fee_structures            FeeStructure[]
  discounts                 Discount[]
  household_fee_assignments HouseholdFeeAssignment[]
  invoices                  Invoice[]
  invoice_lines             InvoiceLine[]
  installments              Installment[]
  payments                  Payment[]
  payment_allocations       PaymentAllocation[]
  receipts                  Receipt[]
  refunds                   Refund[]

  // P6B Relations
  staff_compensations StaffCompensation[]
  payroll_runs        PayrollRun[]
  payroll_entries     PayrollEntry[]
  payslips            Payslip[]

  // P7 Relations
  announcements            Announcement[]
  notification_templates   NotificationTemplate[]
  notifications            Notification[]
  parent_inquiries         ParentInquiry[]
  parent_inquiry_messages  ParentInquiryMessage[]
  website_pages            WebsitePage[]
  contact_form_submissions ContactFormSubmission[]

  // P8 Relations
  audit_logs            AuditLog[]
  compliance_requests   ComplianceRequest[]
  import_jobs           ImportJob[]
  search_index_statuses SearchIndexStatus[]

  @@map("tenants")
}

model TenantDomain {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String             @db.Uuid
  domain              String             @unique @db.VarChar(255)
  domain_type         DomainType
  verification_status VerificationStatus @default(pending)
  ssl_status          SslStatus          @default(pending)
  is_primary          Boolean            @default(false)
  created_at          DateTime           @default(now()) @db.Timestamptz()
  updated_at          DateTime           @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([domain], name: "idx_tenant_domains_domain")
  @@index([tenant_id], name: "idx_tenant_domains_tenant")
  @@map("tenant_domains")
}

model TenantModule {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String  @db.Uuid
  module_key String  @db.VarChar(100)
  is_enabled Boolean

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, module_key], name: "idx_tenant_modules_tenant_module")
  @@index([tenant_id], name: "idx_tenant_modules_tenant")
  @@map("tenant_modules")
}

model TenantBranding {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String   @unique @db.Uuid
  primary_color       String?  @db.VarChar(20)
  secondary_color     String?  @db.VarChar(20)
  logo_url            String?  @db.Text
  school_name_display String?  @db.VarChar(255)
  school_name_ar      String?  @db.VarChar(255)
  email_from_name     String?  @db.VarChar(255)
  email_from_name_ar  String?  @db.VarChar(255)
  support_email       String?  @db.VarChar(255)
  support_phone       String?  @db.VarChar(50)
  receipt_prefix      String   @default("REC") @db.VarChar(30)
  invoice_prefix      String   @default("INV") @db.VarChar(30)
  report_card_title   String?  @db.VarChar(255)
  payslip_prefix      String   @default("PSL") @db.VarChar(30)
  created_at          DateTime @default(now()) @db.Timestamptz()
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("tenant_branding")
}

model TenantSetting {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @unique @db.Uuid
  settings   Json     @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model TenantNotificationSetting {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String  @db.Uuid
  notification_type String  @db.VarChar(100)
  is_enabled        Boolean @default(true)
  channels          Json    @default("[\"email\"]")

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, notification_type])
  @@map("tenant_notification_settings")
}

model TenantSequence {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String @db.Uuid
  sequence_type String @db.VarChar(50)
  current_value BigInt @default(0)

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, sequence_type])
  @@map("tenant_sequences")
}

model TenantStripeConfig {
  id                              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                       String    @unique @db.Uuid
  stripe_secret_key_encrypted     String    @db.Text
  stripe_publishable_key          String    @db.VarChar(255)
  stripe_webhook_secret_encrypted String    @db.Text
  encryption_key_ref              String    @db.VarChar(255)
  key_last_rotated_at             DateTime? @db.Timestamptz()
  created_by_user_id              String?   @db.Uuid
  created_at                      DateTime  @default(now()) @db.Timestamptz()
  updated_at                      DateTime  @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant     Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  created_by User?  @relation(fields: [created_by_user_id], references: [id], onDelete: SetNull)

  @@map("tenant_stripe_configs")
}

// ─── Users & Identity ────────────────────────────────────────────────────────

/// Platform-level table — NOT tenant-scoped, no RLS
model User {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String           @unique @db.Citext
  password_hash     String           @db.Text
  first_name        String           @db.VarChar(100)
  last_name         String           @db.VarChar(100)
  phone             String?          @db.VarChar(50)
  preferred_locale  String?          @db.VarChar(10)
  global_status     UserGlobalStatus @default(active)
  email_verified_at DateTime?        @db.Timestamptz()
  mfa_enabled       Boolean          @default(false)
  mfa_secret        String?          @db.Text
  last_login_at     DateTime?        @db.Timestamptz()
  created_at        DateTime         @default(now()) @db.Timestamptz()
  updated_at        DateTime         @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  memberships                 TenantMembership[]
  mfa_recovery_codes          MfaRecoveryCode[]
  password_reset_tokens       PasswordResetToken[]
  stripe_configs_created      TenantStripeConfig[]
  invitations_sent            Invitation[]
  approval_requests_submitted ApprovalRequest[]    @relation("requester")
  approval_requests_decided   ApprovalRequest[]    @relation("approver")
  ui_preferences              UserUiPreference[]

  // P2 Relations
  staff_profiles StaffProfile[]
  parents        Parent[]

  // P3 Relations
  applications_reviewed ApplicationNote[]
  applications_decided  Application[]     @relation("reviewer")

  // P4A Relations
  school_closures_created       SchoolClosure[]
  attendance_sessions_submitted AttendanceSession[] @relation("session_submitter")
  attendance_records_marked     AttendanceRecord[]  @relation("record_marker")

  // P4B Relations
  scheduling_runs_created SchedulingRun[] @relation("scheduling_run_created_by")
  scheduling_runs_applied SchedulingRun[] @relation("scheduling_run_applied_by")

  // P5 Relations
  grades_entered         Grade[]               @relation("grades_entered")
  period_grade_overrides PeriodGradeSnapshot[] @relation("period_grade_overrides")
  report_cards_published ReportCard[]          @relation("report_card_publisher")

  // P6 Relations
  invoices_created  Invoice[] @relation("invoice_creator")
  payments_posted   Payment[] @relation("payment_poster")
  receipts_issued   Receipt[] @relation("receipt_issuer")
  refunds_requested Refund[]  @relation("refund_requester")
  refunds_approved  Refund[]  @relation("refund_approver")

  // P6B Relations
  compensations_created  StaffCompensation[] @relation("compensation_creator")
  payroll_runs_created   PayrollRun[]        @relation("payroll_run_creator")
  payroll_runs_finalised PayrollRun[]        @relation("payroll_run_finaliser")
  payslips_issued        Payslip[]           @relation("payslip_issuer")

  // P7 Relations
  authored_announcements    Announcement[]         @relation("announcement_author")
  received_notifications    Notification[]         @relation("notification_recipient")
  authored_inquiry_messages ParentInquiryMessage[] @relation("inquiry_message_author")
  authored_website_pages    WebsitePage[]          @relation("website_page_author")

  // P8 Relations
  audit_logs_authored      AuditLog[]          @relation("audit_log_actor")
  compliance_requests_made ComplianceRequest[] @relation("compliance_requested_by")
  import_jobs_created      ImportJob[]         @relation("import_created_by")

  // P4B-v2 Relations
  room_closures_created RoomClosure[] @relation("room_closure_creator")

  @@map("users")
}

/// Append-only, no updated_at
model MfaRecoveryCode {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  code_hash  String    @db.Text
  used_at    DateTime? @db.Timestamptz()
  created_at DateTime  @default(now()) @db.Timestamptz()

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], name: "idx_mfa_recovery_user")
  @@map("mfa_recovery_codes")
}

/// Append-only, no updated_at
model PasswordResetToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @db.Text
  expires_at DateTime  @db.Timestamptz()
  used_at    DateTime? @db.Timestamptz()
  created_at DateTime  @default(now()) @db.Timestamptz()

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], name: "idx_password_reset_tokens_user")
  @@map("password_reset_tokens")
}

// ─── RBAC ────────────────────────────────────────────────────────────────────

model TenantMembership {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String           @db.Uuid
  user_id           String           @db.Uuid
  membership_status MembershipStatus @default(invited)
  joined_at         DateTime?        @db.Timestamptz()
  left_at           DateTime?        @db.Timestamptz()
  created_at        DateTime         @default(now()) @db.Timestamptz()
  updated_at        DateTime         @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant           Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  membership_roles MembershipRole[]

  @@unique([tenant_id, user_id], name: "idx_tenant_memberships_tenant_user")
  @@index([user_id], name: "idx_tenant_memberships_user")
  @@map("tenant_memberships")
}

model Role {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String?  @db.Uuid
  role_key       String   @db.VarChar(100)
  display_name   String   @db.VarChar(100)
  is_system_role Boolean  @default(false)
  role_tier      RoleTier
  created_at     DateTime @default(now()) @db.Timestamptz()
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant             Tenant?            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  role_permissions   RolePermission[]
  membership_roles   MembershipRole[]
  approval_workflows ApprovalWorkflow[]

  @@index([tenant_id], name: "idx_roles_tenant")
  @@map("roles")
}

/// Global permission registry — no tenant_id, no updated_at
model Permission {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  permission_key  String   @unique @db.VarChar(150)
  description     String   @db.Text
  permission_tier RoleTier

  // Relations
  role_permissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  role_id       String  @db.Uuid
  permission_id String  @db.Uuid
  tenant_id     String? @db.Uuid

  // Relations
  role       Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  tenant     Tenant?    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model MembershipRole {
  membership_id String @db.Uuid
  role_id       String @db.Uuid
  tenant_id     String @db.Uuid

  // Relations
  membership TenantMembership @relation(fields: [membership_id], references: [id], onDelete: Cascade)
  role       Role             @relation(fields: [role_id], references: [id], onDelete: Cascade)
  tenant     Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@id([membership_id, role_id])
  @@map("membership_roles")
}

model Invitation {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id            String           @db.Uuid
  email                String           @db.Citext
  invited_role_payload Json
  invited_by_user_id   String           @db.Uuid
  token_hash           String           @db.Text
  expires_at           DateTime         @db.Timestamptz()
  accepted_at          DateTime?        @db.Timestamptz()
  status               InvitationStatus @default(pending)
  created_at           DateTime         @default(now()) @db.Timestamptz()
  updated_at           DateTime         @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant     Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  invited_by User   @relation(fields: [invited_by_user_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, email], name: "idx_invitations_tenant_email")
  @@index([token_hash], name: "idx_invitations_token")
  @@map("invitations")
}

// ─── Approvals ───────────────────────────────────────────────────────────────

model ApprovalWorkflow {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String             @db.Uuid
  action_type      ApprovalActionType
  approver_role_id String             @db.Uuid
  is_enabled       Boolean            @default(true)
  created_at       DateTime           @default(now()) @db.Timestamptz()
  updated_at       DateTime           @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant        Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  approver_role Role   @relation(fields: [approver_role_id], references: [id], onDelete: Cascade)

  @@map("approval_workflows")
}

model ApprovalRequest {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String                @db.Uuid
  action_type        String                @db.VarChar(100)
  target_entity_type String                @db.VarChar(100)
  target_entity_id   String                @db.Uuid
  requester_user_id  String                @db.Uuid
  approver_user_id   String?               @db.Uuid
  status             ApprovalRequestStatus @default(pending_approval)
  request_comment    String?               @db.Text
  decision_comment   String?               @db.Text
  submitted_at       DateTime              @default(now()) @db.Timestamptz()
  decided_at         DateTime?             @db.Timestamptz()
  executed_at        DateTime?             @db.Timestamptz()
  created_at         DateTime              @default(now()) @db.Timestamptz()
  updated_at         DateTime              @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant    Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  requester User   @relation("requester", fields: [requester_user_id], references: [id], onDelete: Cascade)
  approver  User?  @relation("approver", fields: [approver_user_id], references: [id], onDelete: SetNull)

  // P6 Relations
  invoices Invoice[]

