  // Relations
  tenant Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("notification_templates")
}

model Notification {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String              @db.Uuid
  recipient_user_id   String              @db.Uuid
  channel             NotificationChannel
  template_key        String?             @db.VarChar(100)
  locale              String              @db.VarChar(10)
  status              NotificationStatus  @default(queued)
  provider_message_id String?             @db.VarChar(255)
  payload_json        Json
  source_entity_type  String?             @db.VarChar(100)
  source_entity_id    String?             @db.Uuid
  failure_reason      String?
  attempt_count       Int                 @default(0) @db.SmallInt
  max_attempts        Int                 @default(3) @db.SmallInt
  next_retry_at       DateTime?           @db.Timestamptz(6)
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  sent_at             DateTime?           @db.Timestamptz(6)
  delivered_at        DateTime?           @db.Timestamptz(6)
  read_at             DateTime?           @db.Timestamptz(6)

  // Relations
  tenant    Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  recipient User   @relation("notification_recipient", fields: [recipient_user_id], references: [id])

  @@index([tenant_id, recipient_user_id, status], name: "idx_notifications_tenant_recipient")
  @@map("notifications")
}

// ─── P7: Parent Inquiries ────────────────────────────────────────────────────

model ParentInquiry {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String              @db.Uuid
  parent_id  String              @db.Uuid
  student_id String?             @db.Uuid
  subject    String              @db.VarChar(255)
  status     ParentInquiryStatus @default(open)
  created_at DateTime            @default(now()) @db.Timestamptz(6)
  updated_at DateTime            @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  tenant   Tenant                 @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  parent   Parent                 @relation(fields: [parent_id], references: [id])
  student  Student?               @relation(fields: [student_id], references: [id])
  messages ParentInquiryMessage[]

  @@index([tenant_id, status], name: "idx_parent_inquiries_tenant_status")
  @@map("parent_inquiries")
}

model ParentInquiryMessage {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String            @db.Uuid
  inquiry_id     String            @db.Uuid
  author_type    InquiryAuthorType
  author_user_id String            @db.Uuid
  message        String
  created_at     DateTime          @default(now()) @db.Timestamptz(6)

  // Relations
  tenant  Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  inquiry ParentInquiry @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)
  author  User          @relation("inquiry_message_author", fields: [author_user_id], references: [id])

  @@index([inquiry_id], name: "idx_parent_inquiry_messages_inquiry")
  @@map("parent_inquiry_messages")
}

// ─── P7: Website CMS ─────────────────────────────────────────────────────────

model WebsitePage {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String            @db.Uuid
  locale           String            @default("en") @db.VarChar(10)
  page_type        WebsitePageType
  slug             String            @db.VarChar(150)
  title            String            @db.VarChar(255)
  meta_title       String?           @db.VarChar(255)
  meta_description String?
  body_html        String
  status           WebsitePageStatus @default(draft)
  show_in_nav      Boolean           @default(false)
  nav_order        Int               @default(0)
  author_user_id   String            @db.Uuid
  published_at     DateTime?         @db.Timestamptz(6)
  created_at       DateTime          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime          @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  author User   @relation("website_page_author", fields: [author_user_id], references: [id])

  @@unique([tenant_id, slug, locale], name: "idx_website_pages_slug")
  @@index([tenant_id, locale, status], name: "idx_website_pages_tenant_locale")
  @@map("website_pages")
}

model ContactFormSubmission {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String            @db.Uuid
  name       String            @db.VarChar(255)
  email      String            @db.Citext
  phone      String?           @db.VarChar(50)
  message    String
  source_ip  String?           @db.Inet
  status     ContactFormStatus @default(new_submission)
  created_at DateTime          @default(now()) @db.Timestamptz(6)
  updated_at DateTime          @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, status], name: "idx_contact_submissions_tenant")
  @@map("contact_form_submissions")
}

// ─── P8 Enums ──────────────────────────────────────────────────────────────

enum ComplianceRequestType {
  access_export
  erasure
  rectification
}

enum ComplianceSubjectType {
  parent
  student
  household
  user
}

enum ComplianceRequestStatus {
  submitted
  classified
  approved
  rejected
  completed
}

enum ComplianceClassification {
  erase
  anonymise
  retain_legal_basis
}

enum ImportType {
  students
  parents
  staff
  fees
  exam_results
  staff_compensation
}

enum ImportStatus {
  uploaded
  validated
  processing
  completed
  failed
}

enum SearchIndexStatusEnum {
  pending
  indexed
  search_failed
}

// ─── P8: Audit Logs ─────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String?  @db.Uuid
  actor_user_id String?  @db.Uuid
  entity_type   String   @db.VarChar(100)
  entity_id     String?  @db.Uuid
  action        String   @db.VarChar(100)
  metadata_json Json     @default("{}")
  ip_address    String?  @db.VarChar(45)
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  tenant Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  actor  User?   @relation("audit_log_actor", fields: [actor_user_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, entity_type, entity_id], name: "idx_audit_logs_tenant_entity")
  @@index([tenant_id, actor_user_id], name: "idx_audit_logs_tenant_actor")
  @@index([tenant_id, created_at], name: "idx_audit_logs_created")
  @@map("audit_logs")
}

// ─── P8: Compliance Requests ────────────────────────────────────────────────

model ComplianceRequest {
  id                   String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id            String                    @db.Uuid
  request_type         ComplianceRequestType
  subject_type         ComplianceSubjectType
  subject_id           String                    @db.Uuid
  requested_by_user_id String                    @db.Uuid
  status               ComplianceRequestStatus   @default(submitted)
  classification       ComplianceClassification?
  decision_notes       String?
  export_file_key      String?
  created_at           DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime                  @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  tenant       Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  requested_by User   @relation("compliance_requested_by", fields: [requested_by_user_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, status], name: "idx_compliance_requests_tenant")
  @@map("compliance_requests")
}

// ─── P8: Import Jobs ────────────────────────────────────────────────────────

model ImportJob {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String       @db.Uuid
  import_type        ImportType
  file_key           String?
  status             ImportStatus @default(uploaded)
  summary_json       Json         @default("{}")
  created_by_user_id String       @db.Uuid
  created_at         DateTime     @default(now()) @db.Timestamptz(6)
  updated_at         DateTime     @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  tenant     Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  created_by User   @relation("import_created_by", fields: [created_by_user_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, status], name: "idx_import_jobs_tenant")
  @@map("import_jobs")
}

// ─── P8: Search Index Status ────────────────────────────────────────────────

model SearchIndexStatus {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String                @db.Uuid
  entity_type  String                @db.VarChar(100)
  entity_id    String                @db.Uuid
  index_status SearchIndexStatusEnum @default(pending)
  updated_at   DateTime              @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, entity_type, entity_id], name: "idx_search_index_status_unique")
  @@index([tenant_id, index_status], name: "idx_search_index_status_pending")
  @@map("search_index_status")
}
