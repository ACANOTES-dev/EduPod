/// Append-only, no updated_at
model MfaRecoveryCode {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  code_hash  String    @db.Text
  used_at    DateTime? @db.Timestamptz()
  created_at DateTime  @default(now()) @db.Timestamptz()

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], name: "idx_mfa_recovery_user")
  @@map("mfa_recovery_codes")
}

/// Append-only, no updated_at
model PasswordResetToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @db.Text
  expires_at DateTime  @db.Timestamptz()
  used_at    DateTime? @db.Timestamptz()
  created_at DateTime  @default(now()) @db.Timestamptz()

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], name: "idx_password_reset_tokens_user")
  @@map("password_reset_tokens")
}

// ─── RBAC ────────────────────────────────────────────────────────────────────

model TenantMembership {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String           @db.Uuid
  user_id           String           @db.Uuid
  membership_status MembershipStatus @default(invited)
  joined_at         DateTime?        @db.Timestamptz()
  left_at           DateTime?        @db.Timestamptz()
  created_at        DateTime         @default(now()) @db.Timestamptz()
  updated_at        DateTime         @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant           Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  membership_roles MembershipRole[]

  @@unique([tenant_id, user_id], name: "idx_tenant_memberships_tenant_user")
  @@index([user_id], name: "idx_tenant_memberships_user")
  @@map("tenant_memberships")
}

model Role {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String?  @db.Uuid
  role_key       String   @db.VarChar(100)
  display_name   String   @db.VarChar(100)
  is_system_role Boolean  @default(false)
  role_tier      RoleTier
  created_at     DateTime @default(now()) @db.Timestamptz()
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant             Tenant?            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  role_permissions   RolePermission[]
  membership_roles   MembershipRole[]
  approval_workflows ApprovalWorkflow[]

  @@index([tenant_id], name: "idx_roles_tenant")
  @@map("roles")
}

/// Global permission registry — no tenant_id, no updated_at
model Permission {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  permission_key  String   @unique @db.VarChar(150)
  description     String   @db.Text
  permission_tier RoleTier

  // Relations
  role_permissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  role_id       String  @db.Uuid
  permission_id String  @db.Uuid
  tenant_id     String? @db.Uuid

  // Relations
  role       Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  tenant     Tenant?    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@index([tenant_id], name: "idx_role_permissions_tenant")
  @@map("role_permissions")
}

model MembershipRole {
  membership_id String @db.Uuid
  role_id       String @db.Uuid
  tenant_id     String @db.Uuid

  // Relations
  membership TenantMembership @relation(fields: [membership_id], references: [id], onDelete: Cascade)
  role       Role             @relation(fields: [role_id], references: [id], onDelete: Cascade)
  tenant     Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@id([membership_id, role_id])
  @@index([tenant_id], name: "idx_membership_roles_tenant")
  @@map("membership_roles")
}

model Invitation {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id            String           @db.Uuid
  email                String           @db.Citext
  invited_role_payload Json
  invited_by_user_id   String           @db.Uuid
  token_hash           String           @db.Text
  expires_at           DateTime         @db.Timestamptz()
  accepted_at          DateTime?        @db.Timestamptz()
  status               InvitationStatus @default(pending)
  created_at           DateTime         @default(now()) @db.Timestamptz()
  updated_at           DateTime         @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant     Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  invited_by User   @relation(fields: [invited_by_user_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, email], name: "idx_invitations_tenant_email")
  @@index([token_hash], name: "idx_invitations_token")
  @@map("invitations")
}

// ─── Approvals ───────────────────────────────────────────────────────────────

model ApprovalWorkflow {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String             @db.Uuid
  action_type      ApprovalActionType
  approver_role_id String             @db.Uuid
  is_enabled       Boolean            @default(true)
  created_at       DateTime           @default(now()) @db.Timestamptz()
  updated_at       DateTime           @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant        Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  approver_role Role   @relation(fields: [approver_role_id], references: [id], onDelete: Cascade)

  @@index([tenant_id], name: "idx_approval_workflows_tenant")
  @@map("approval_workflows")
}

model ApprovalRequest {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String                @db.Uuid
  action_type        String                @db.VarChar(100)
  target_entity_type String                @db.VarChar(100)
  target_entity_id   String                @db.Uuid
  requester_user_id  String                @db.Uuid
  approver_user_id   String?               @db.Uuid
  status             ApprovalRequestStatus @default(pending_approval)
  request_comment    String?               @db.Text
  decision_comment   String?               @db.Text
  submitted_at       DateTime              @default(now()) @db.Timestamptz()
  decided_at         DateTime?             @db.Timestamptz()
  executed_at        DateTime?             @db.Timestamptz()
  callback_status    String?               @db.VarChar(20) // pending | executed | failed
  callback_error     String?               @db.Text
  callback_attempts  Int                   @default(0)
  created_at         DateTime              @default(now()) @db.Timestamptz()
  updated_at         DateTime              @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant    Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  requester User   @relation("requester", fields: [requester_user_id], references: [id], onDelete: Cascade)
  approver  User?  @relation("approver", fields: [approver_user_id], references: [id], onDelete: SetNull)

  // P6 Relations
  invoices Invoice[]

  // P6B Relations
  payroll_runs PayrollRun[]

  // P7 Relations
  announcements Announcement[]

  // Behaviour Management Relations
  bh_incidents BehaviourIncident[] @relation("bh_incident_approval")
  bh_sanctions BehaviourSanction[] @relation("bh_sanction_approval")

  @@index([tenant_id, status], name: "idx_approval_requests_tenant_status")
  @@index([callback_status], name: "idx_approval_requests_callback_status")
  @@map("approval_requests")
}

// ─── User UI Preferences ─────────────────────────────────────────────────────

model UserUiPreference {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  user_id     String   @db.Uuid
  preferences Json     @default("{}")
  created_at  DateTime @default(now()) @db.Timestamptz()
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz()

