// ─── Engagement Module ───────────────────────────────────────────────────────

model EngagementFormTemplate {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String               @db.Uuid
  name               String               @db.VarChar(255)
  description        String?              @db.Text
  form_type          EngagementFormType
  consent_type       ConsentType?
  fields_json        Json
  requires_signature Boolean              @default(false)
  status             EngagementFormStatus @default(draft)
  academic_year_id   String?              @db.Uuid
  created_by_user_id String               @db.Uuid
  created_at         DateTime             @default(now()) @db.Timestamptz()
  updated_at         DateTime             @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant          Tenant                    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  academic_year   AcademicYear?             @relation(fields: [academic_year_id], references: [id], onDelete: SetNull)
  created_by      User                      @relation("eng_form_template_creator", fields: [created_by_user_id], references: [id])
  submissions     EngagementFormSubmission[]
  consent_records EngagementConsentRecord[]
  events_consent  EngagementEvent[]         @relation("event_consent_form")
  events_risk     EngagementEvent[]         @relation("event_risk_assessment")

  @@index([tenant_id, status], name: "idx_eng_form_templates_tenant_status")
  @@index([tenant_id, form_type], name: "idx_eng_form_templates_tenant_type")
  @@map("engagement_form_templates")
}

model EngagementFormSubmission {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id            String               @db.Uuid
  form_template_id     String               @db.Uuid
  event_id             String?              @db.Uuid
  student_id           String               @db.Uuid
  submitted_by_user_id String?              @db.Uuid
  responses_json       Json
  signature_json       Json?
  status               FormSubmissionStatus @default(pending)
  submitted_at         DateTime?            @db.Timestamptz()
  acknowledged_at      DateTime?            @db.Timestamptz()
  acknowledged_by_id   String?              @db.Uuid
  expired_at           DateTime?            @db.Timestamptz()
  revoked_at           DateTime?            @db.Timestamptz()
  revocation_reason    String?              @db.Text
  academic_year_id     String               @db.Uuid
  created_at           DateTime             @default(now()) @db.Timestamptz()
  updated_at           DateTime             @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant          Tenant                   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  form_template   EngagementFormTemplate   @relation(fields: [form_template_id], references: [id], onDelete: Cascade)
  event           EngagementEvent?         @relation(fields: [event_id], references: [id], onDelete: SetNull)
  student         Student                  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  submitted_by    User?                    @relation("eng_form_submitter", fields: [submitted_by_user_id], references: [id], onDelete: SetNull)
  acknowledged_by User?                    @relation("eng_form_acknowledger", fields: [acknowledged_by_id], references: [id], onDelete: SetNull)
  academic_year   AcademicYear             @relation(fields: [academic_year_id], references: [id])
  consent_record  EngagementConsentRecord?

  @@index([tenant_id, form_template_id, status], name: "idx_eng_submissions_template_status")
  @@index([tenant_id, student_id], name: "idx_eng_submissions_student")
  @@index([tenant_id, event_id, status], name: "idx_eng_submissions_event_status")
  @@map("engagement_form_submissions")
}

model EngagementConsentRecord {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String              @db.Uuid
  student_id         String              @db.Uuid
  consent_type       ConsentType
  form_template_id   String              @db.Uuid
  form_submission_id String              @unique @db.Uuid
  event_id           String?             @db.Uuid
  status             ConsentRecordStatus @default(active)
  granted_at         DateTime            @db.Timestamptz()
  expires_at         DateTime?           @db.Timestamptz()
  revoked_at         DateTime?           @db.Timestamptz()
  academic_year_id   String              @db.Uuid
  created_at         DateTime            @default(now()) @db.Timestamptz()
  updated_at         DateTime            @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant          Tenant                  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  student         Student                 @relation(fields: [student_id], references: [id], onDelete: Cascade)
  form_template   EngagementFormTemplate  @relation(fields: [form_template_id], references: [id], onDelete: Cascade)
  form_submission EngagementFormSubmission @relation(fields: [form_submission_id], references: [id], onDelete: Cascade)
  event           EngagementEvent?        @relation(fields: [event_id], references: [id], onDelete: SetNull)
  academic_year   AcademicYear            @relation(fields: [academic_year_id], references: [id])

  @@index([tenant_id, student_id, status], name: "idx_eng_consent_student_status")
  @@index([tenant_id, consent_type, status], name: "idx_eng_consent_type_status")
  @@index([tenant_id, expires_at], name: "idx_eng_consent_expires")
  @@map("engagement_consent_records")
}

model EngagementEvent {
  id                          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                   String                @db.Uuid
  title                       String                @db.VarChar(255)
  title_ar                    String?               @db.VarChar(255)
  description                 String?               @db.Text
  description_ar              String?               @db.Text
  event_type                  EngagementEventType
  status                      EngagementEventStatus @default(draft)

  // ─── Scheduling ──────────────────────────────────────────────────────────────
  start_date                  DateTime?             @db.Date
  end_date                    DateTime?             @db.Date
  start_time                  DateTime?             @db.Time
  end_time                    DateTime?             @db.Time
  location                    String?               @db.VarChar(255)
  location_ar                 String?               @db.VarChar(255)

  // ─── Targeting ───────────────────────────────────────────────────────────────
  capacity                    Int?
  target_type                 EventTargetType       @default(whole_school)
  target_config_json          Json?

  // ─── Linked forms ────────────────────────────────────────────────────────────
  consent_form_template_id    String?               @db.Uuid
  risk_assessment_template_id String?               @db.Uuid

  // ─── Payment ─────────────────────────────────────────────────────────────────
  fee_amount                  Decimal?              @db.Decimal(12, 2)
  fee_description             String?               @db.VarChar(255)

  // ─── Conference-specific ─────────────────────────────────────────────────────
  slot_duration_minutes       Int?
  buffer_minutes              Int?

  // ─── Deadlines ───────────────────────────────────────────────────────────────
  consent_deadline            DateTime?             @db.Date
  payment_deadline            DateTime?             @db.Date
  booking_deadline            DateTime?             @db.Date

  // ─── Risk assessment gate ────────────────────────────────────────────────────
  risk_assessment_required    Boolean               @default(false)
  risk_assessment_approved    Boolean               @default(false)
  risk_assessment_approved_by String?               @db.Uuid
  risk_assessment_approved_at DateTime?             @db.Timestamptz()

  // ─── Metadata ────────────────────────────────────────────────────────────────
  academic_year_id            String                @db.Uuid
  created_by_user_id          String                @db.Uuid
  created_at                  DateTime              @default(now()) @db.Timestamptz()
  updated_at                  DateTime              @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant                   Tenant                      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  consent_form_template    EngagementFormTemplate?      @relation("event_consent_form", fields: [consent_form_template_id], references: [id], onDelete: SetNull)
  risk_assessment_template EngagementFormTemplate?      @relation("event_risk_assessment", fields: [risk_assessment_template_id], references: [id], onDelete: SetNull)
  academic_year            AcademicYear                 @relation(fields: [academic_year_id], references: [id])
  created_by               User                         @relation("eng_event_creator", fields: [created_by_user_id], references: [id])
  risk_approver            User?                        @relation("eng_risk_approver", fields: [risk_assessment_approved_by], references: [id], onDelete: SetNull)
  staff                    EngagementEventStaff[]
  participants             EngagementEventParticipant[]
  form_submissions         EngagementFormSubmission[]
  consent_records          EngagementConsentRecord[]
  time_slots               ConferenceTimeSlot[]
  incident_reports         EngagementIncidentReport[]

  @@index([tenant_id, status], name: "idx_eng_events_tenant_status")
  @@index([tenant_id, event_type, status], name: "idx_eng_events_type_status")
  @@index([tenant_id, academic_year_id], name: "idx_eng_events_academic_year")
  @@index([tenant_id, start_date], name: "idx_eng_events_start_date")
  @@map("engagement_events")
}

model EngagementEventStaff {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String         @db.Uuid
  event_id   String         @db.Uuid
  staff_id   String         @db.Uuid
  role       EventStaffRole
  created_at DateTime       @default(now()) @db.Timestamptz()

  // Relations
  tenant Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  event  EngagementEvent @relation(fields: [event_id], references: [id], onDelete: Cascade)
  staff  StaffProfile    @relation(fields: [staff_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, event_id, staff_id], name: "uq_eng_event_staff")
  @@map("engagement_event_staff")
}

model EngagementEventParticipant {
  id                   String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id            String                    @db.Uuid
  event_id             String                    @db.Uuid
  student_id           String                    @db.Uuid
  status               ParticipantStatus         @default(invited)
  consent_status       ParticipantConsentStatus? @default(pending)
  payment_status       ParticipantPaymentStatus  @default(not_required)
  invoice_id           String?                   @db.Uuid
  registered_at        DateTime?                 @db.Timestamptz()
  attendance_marked    Boolean                   @default(false)
  attendance_marked_at DateTime?                 @db.Timestamptz()
  attendance_marked_by String?                   @db.Uuid
  withdrawn_at         DateTime?                 @db.Timestamptz()
  created_at           DateTime                  @default(now()) @db.Timestamptz()
  updated_at           DateTime                  @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant  Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  event   EngagementEvent @relation(fields: [event_id], references: [id], onDelete: Cascade)
  student Student         @relation(fields: [student_id], references: [id], onDelete: Cascade)
  invoice Invoice?        @relation(fields: [invoice_id], references: [id], onDelete: SetNull)

  @@unique([tenant_id, event_id, student_id], name: "uq_eng_event_participant")
  @@index([tenant_id, event_id, status], name: "idx_eng_participants_event_status")
  @@map("engagement_event_participants")
}

model ConferenceTimeSlot {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String         @db.Uuid
  event_id   String         @db.Uuid
  teacher_id String         @db.Uuid
  start_time DateTime       @db.Timestamptz()
  end_time   DateTime       @db.Timestamptz()
  status     TimeSlotStatus @default(available)
  created_at DateTime       @default(now()) @db.Timestamptz()
  updated_at DateTime       @default(now()) @updatedAt @db.Timestamptz()

