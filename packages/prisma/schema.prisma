model ConferenceBooking {
  id                String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String                  @db.Uuid
  time_slot_id      String                  @unique @db.Uuid
  student_id        String                  @db.Uuid
  booked_by_user_id String                  @db.Uuid
