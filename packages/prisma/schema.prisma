// ─── Platform & Tenancy ──────────────────────────────────────────────────────

model Tenant {
  id                        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                      String       @db.VarChar(255)
  slug                      String       @unique @db.VarChar(100)
  status                    TenantStatus @default(active)
  default_locale            String       @default("en") @db.VarChar(10)
  timezone                  String       @db.VarChar(100)
  date_format               String       @db.VarChar(50)
  currency_code             String       @db.VarChar(10)
  academic_year_start_month Int          @db.SmallInt
  created_at                DateTime     @default(now()) @db.Timestamptz()
  updated_at                DateTime     @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  domains               TenantDomain[]
  modules               TenantModule[]
  branding              TenantBranding?
  settings              TenantSetting?
  notification_settings TenantNotificationSetting[]
  sequences             TenantSequence[]
  stripe_config         TenantStripeConfig?
  memberships           TenantMembership[]
  roles                 Role[]
  role_permissions      RolePermission[]
  membership_roles      MembershipRole[]
  invitations           Invitation[]
  approval_workflows    ApprovalWorkflow[]
  approval_requests     ApprovalRequest[]
  user_ui_preferences   UserUiPreference[]

  // P2 Relations
  households                   Household[]
  household_emergency_contacts HouseholdEmergencyContact[]
  parents                      Parent[]
  household_parents            HouseholdParent[]
  students                     Student[]
  student_parents              StudentParent[]
  staff_profiles               StaffProfile[]
  academic_years               AcademicYear[]
  academic_periods             AcademicPeriod[]
  year_groups                  YearGroup[]
  subjects                     Subject[]
  classes                      Class[]
  class_staff                  ClassStaff[]
  class_enrolments             ClassEnrolment[]

  // P3 Relations
  admission_form_definitions AdmissionFormDefinition[]
  admission_form_fields      AdmissionFormField[]
  applications               Application[]
  application_notes          ApplicationNote[]

  // P4A Relations
  rooms                      Room[]
  schedules                  Schedule[]
  school_closures            SchoolClosure[]
  attendance_sessions        AttendanceSession[]
  attendance_records         AttendanceRecord[]
  daily_attendance_summaries DailyAttendanceSummary[]
  attendance_pattern_alerts  AttendancePatternAlert[]

  // P4B Relations
  schedule_period_templates     SchedulePeriodTemplate[]
  class_scheduling_requirements ClassSchedulingRequirement[]
  staff_availability            StaffAvailability[]
  staff_scheduling_preferences  StaffSchedulingPreference[]
  scheduling_runs               SchedulingRun[]

  // P4B-v2 Relations
  curriculum_requirements    CurriculumRequirement[]
  teacher_competencies       TeacherCompetency[]
  break_groups               BreakGroup[]
  break_group_year_groups    BreakGroupYearGroup[]
  room_closures              RoomClosure[]
  teacher_scheduling_configs TeacherSchedulingConfig[]

  // P5 Relations
  grading_scales              GradingScale[]
  assessment_categories       AssessmentCategory[]
  class_subject_grade_configs ClassSubjectGradeConfig[]
  assessments                 Assessment[]
  grades                      Grade[]
  period_grade_snapshots      PeriodGradeSnapshot[]
  report_cards                ReportCard[]

  // Gradebook Phase D Relations
  year_group_grade_weights YearGroupGradeWeight[]

  // P5+ World-Class Gradebook Relations
  rubric_templates             RubricTemplate[]
  rubric_grades                RubricGrade[]
  curriculum_standards         CurriculumStandard[]
  assessment_standard_mappings AssessmentStandardMapping[]
  competency_scales            CompetencyScale[]
  student_competency_snapshots StudentCompetencySnapshot[]
  gpa_snapshots                GpaSnapshot[]
  grade_curve_audits           GradeCurveAudit[]
  assessment_templates         AssessmentTemplate[]
  ai_grading_instructions      AiGradingInstruction[]
  ai_grading_references        AiGradingReference[]
  student_academic_risk_alerts StudentAcademicRiskAlert[]
  progress_reports             ProgressReport[]
  progress_report_entries      ProgressReportEntry[]
  nl_query_history             NlQueryHistory[]

  // Report Cards Enhancement Relations
  report_card_templates           ReportCardTemplate[]
  report_card_approval_configs    ReportCardApprovalConfig[]
  report_card_approvals           ReportCardApproval[]
  report_card_deliveries          ReportCardDelivery[]
  report_card_batch_jobs          ReportCardBatchJob[]
  report_card_custom_field_defs   ReportCardCustomFieldDef[]
  report_card_custom_field_values ReportCardCustomFieldValue[]
  grade_threshold_configs         GradeThresholdConfig[]
  report_card_acknowledgments     ReportCardAcknowledgment[]
  report_card_verification_tokens ReportCardVerificationToken[]

  // P6 Relations
  fee_structures            FeeStructure[]
  discounts                 Discount[]
  household_fee_assignments HouseholdFeeAssignment[]
  invoices                  Invoice[]
  invoice_lines             InvoiceLine[]
  installments              Installment[]
  payments                  Payment[]
  payment_allocations       PaymentAllocation[]
  receipts                  Receipt[]
  refunds                   Refund[]

  // P6 Finance World-Class Relations
  invoice_reminders         InvoiceReminder[]
  recurring_invoice_configs RecurringInvoiceConfig[]
  credit_notes              CreditNote[]
  credit_note_applications  CreditNoteApplication[]
  late_fee_configs          LateFeeConfig[]
  late_fee_applications     LateFeeApplication[]
  payment_plan_requests     PaymentPlanRequest[]
  scholarships              Scholarship[]

  // P6B Relations
  staff_compensations StaffCompensation[]
  payroll_runs        PayrollRun[]
  payroll_entries     PayrollEntry[]
  payslips            Payslip[]

  // Payroll World-Class Relations
  staff_attendance_records   StaffAttendanceRecord[]
  class_delivery_records     ClassDeliveryRecord[]
  payroll_adjustments        PayrollAdjustment[]
  payroll_export_templates   PayrollExportTemplate[]
  payroll_export_logs        PayrollExportLog[]
  payroll_approval_configs   PayrollApprovalConfig[]
  payroll_allowance_types    PayrollAllowanceType[]
  staff_allowances           StaffAllowance[]
  payroll_one_off_items      PayrollOneOffItem[]
  staff_recurring_deductions StaffRecurringDeduction[]

  // P7 Relations
  announcements            Announcement[]
  notification_templates   NotificationTemplate[]
  notifications            Notification[]
  parent_inquiries         ParentInquiry[]
  parent_inquiry_messages  ParentInquiryMessage[]
  website_pages            WebsitePage[]
  contact_form_submissions ContactFormSubmission[]

  // P8 Relations
  audit_logs            AuditLog[]
  compliance_requests   ComplianceRequest[]
  import_jobs           ImportJob[]
  import_job_records    ImportJobRecord[]
  search_index_statuses SearchIndexStatus[]

  // Scheduling World-Class Relations
  teacher_absences             TeacherAbsence[]
  substitution_records         SubstitutionRecord[]
  calendar_subscription_tokens CalendarSubscriptionToken[]
  exam_sessions                ExamSession[]
  exam_slots                   ExamSlot[]
  exam_invigilations           ExamInvigilation[]
  scheduling_scenarios         SchedulingScenario[]
  rotation_configs             RotationConfig[]

  @@map("tenants")
}

model TenantDomain {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String             @db.Uuid
  domain              String             @unique @db.VarChar(255)
  domain_type         DomainType
  verification_status VerificationStatus @default(pending)
  ssl_status          SslStatus          @default(pending)
  is_primary          Boolean            @default(false)
  created_at          DateTime           @default(now()) @db.Timestamptz()
  updated_at          DateTime           @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([domain], name: "idx_tenant_domains_domain")
  @@index([tenant_id], name: "idx_tenant_domains_tenant")
  @@map("tenant_domains")
}

model TenantModule {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String  @db.Uuid
  module_key String  @db.VarChar(100)
  is_enabled Boolean

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, module_key], name: "idx_tenant_modules_tenant_module")
  @@index([tenant_id], name: "idx_tenant_modules_tenant")
  @@map("tenant_modules")
}

model TenantBranding {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String   @unique @db.Uuid
  primary_color       String?  @db.VarChar(20)
  secondary_color     String?  @db.VarChar(20)
  logo_url            String?  @db.Text
  school_name_display String?  @db.VarChar(255)
  school_name_ar      String?  @db.VarChar(255)
  email_from_name     String?  @db.VarChar(255)
  email_from_name_ar  String?  @db.VarChar(255)
  support_email       String?  @db.VarChar(255)
  support_phone       String?  @db.VarChar(50)
  receipt_prefix      String   @default("REC") @db.VarChar(30)
  invoice_prefix      String   @default("INV") @db.VarChar(30)
  report_card_title   String?  @db.VarChar(255)
  payslip_prefix      String   @default("PSL") @db.VarChar(30)
  created_at          DateTime @default(now()) @db.Timestamptz()
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("tenant_branding")
}

model TenantSetting {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @unique @db.Uuid
  settings   Json     @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model TenantNotificationSetting {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String  @db.Uuid
  notification_type String  @db.VarChar(100)
  is_enabled        Boolean @default(true)
  channels          Json    @default("[\"email\"]")

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, notification_type])
  @@map("tenant_notification_settings")
}

model TenantSequence {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String @db.Uuid
  sequence_type String @db.VarChar(50)
  current_value BigInt @default(0)

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, sequence_type])
  @@map("tenant_sequences")
}

model TenantStripeConfig {
  id                              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                       String    @unique @db.Uuid
  stripe_secret_key_encrypted     String    @db.Text
  stripe_publishable_key          String    @db.VarChar(255)
  stripe_webhook_secret_encrypted String    @db.Text
  encryption_key_ref              String    @db.VarChar(255)
  key_last_rotated_at             DateTime? @db.Timestamptz()
  created_by_user_id              String?   @db.Uuid
  created_at                      DateTime  @default(now()) @db.Timestamptz()
  updated_at                      DateTime  @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant     Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  created_by User?  @relation(fields: [created_by_user_id], references: [id], onDelete: SetNull)

  @@map("tenant_stripe_configs")
}

// ─── Users & Identity ────────────────────────────────────────────────────────

/// Platform-level table — NOT tenant-scoped, no RLS
model User {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String           @unique @db.Citext
  password_hash     String           @db.Text
  first_name        String           @db.VarChar(100)
  last_name         String           @db.VarChar(100)
  phone             String?          @db.VarChar(50)
  preferred_locale  String?          @db.VarChar(10)
  global_status     UserGlobalStatus @default(active)
  email_verified_at DateTime?        @db.Timestamptz()
  mfa_enabled       Boolean          @default(false)
  mfa_secret        String?          @db.Text
  last_login_at     DateTime?        @db.Timestamptz()
  created_at        DateTime         @default(now()) @db.Timestamptz()
  updated_at        DateTime         @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  memberships                 TenantMembership[]
  mfa_recovery_codes          MfaRecoveryCode[]
  password_reset_tokens       PasswordResetToken[]
  stripe_configs_created      TenantStripeConfig[]
  invitations_sent            Invitation[]
  approval_requests_submitted ApprovalRequest[]    @relation("requester")
  approval_requests_decided   ApprovalRequest[]    @relation("approver")
  ui_preferences              UserUiPreference[]

  // P2 Relations
  staff_profiles StaffProfile[]
  parents        Parent[]

  // P3 Relations
  applications_reviewed ApplicationNote[]
  applications_decided  Application[]     @relation("reviewer")

  // P4A Relations
  school_closures_created       SchoolClosure[]
  attendance_sessions_submitted AttendanceSession[]      @relation("session_submitter")
  attendance_records_marked     AttendanceRecord[]       @relation("record_marker")
  acknowledged_alerts           AttendancePatternAlert[] @relation("alert_acknowledger")

  // P4B Relations
  scheduling_runs_created SchedulingRun[] @relation("scheduling_run_created_by")
  scheduling_runs_applied SchedulingRun[] @relation("scheduling_run_applied_by")

  // P5 Relations
  grades_entered         Grade[]               @relation("grades_entered")
  period_grade_overrides PeriodGradeSnapshot[] @relation("period_grade_overrides")
  report_cards_published ReportCard[]          @relation("report_card_publisher")

  // P6 Relations
  invoices_created         Invoice[]               @relation("invoice_creator")
  payments_posted          Payment[]               @relation("payment_poster")
  receipts_issued          Receipt[]               @relation("receipt_issuer")
  refunds_requested        Refund[]                @relation("refund_requester")
  refunds_approved         Refund[]                @relation("refund_approver")
  credit_notes_issued      CreditNote[]            @relation("credit_note_issuer")
  credit_note_applications CreditNoteApplication[] @relation("credit_note_applier")
  payment_plans_reviewed   PaymentPlanRequest[]    @relation("payment_plan_reviewer")
  scholarships_awarded     Scholarship[]           @relation("scholarship_awarder")

  // P6B Relations
  compensations_created   StaffCompensation[] @relation("compensation_creator")
  payroll_runs_created    PayrollRun[]        @relation("payroll_run_creator")
  payroll_runs_finalised  PayrollRun[]        @relation("payroll_run_finaliser")
  payroll_entry_overrides PayrollEntry[]      @relation("payroll_entry_override_by")
  payslips_issued         Payslip[]           @relation("payslip_issuer")

  // Payroll World-Class Relations
  staff_attendance_marked          StaffAttendanceRecord[]   @relation("attendance_marker")
  class_deliveries_confirmed       ClassDeliveryRecord[]     @relation("delivery_confirmer")
  payroll_adjustments_created      PayrollAdjustment[]       @relation("adjustment_creator")
  payroll_export_templates_created PayrollExportTemplate[]   @relation("export_template_creator")
  payroll_exports_done             PayrollExportLog[]        @relation("export_log_exporter")
  payroll_one_off_items_created    PayrollOneOffItem[]       @relation("one_off_creator")
  staff_deductions_created         StaffRecurringDeduction[] @relation("deduction_creator")

  // P7 Relations
  authored_announcements    Announcement[]         @relation("announcement_author")
  received_notifications    Notification[]         @relation("notification_recipient")
  authored_inquiry_messages ParentInquiryMessage[] @relation("inquiry_message_author")
  authored_website_pages    WebsitePage[]          @relation("website_page_author")

  // P8 Relations
  audit_logs_authored      AuditLog[]          @relation("audit_log_actor")
  compliance_requests_made ComplianceRequest[] @relation("compliance_requested_by")
  import_jobs_created      ImportJob[]         @relation("import_created_by")

  // P4B-v2 Relations
  room_closures_created RoomClosure[] @relation("room_closure_creator")

  // P5+ World-Class Gradebook Relations
  rubric_templates_created     RubricTemplate[]           @relation("rubric_template_creator")
  assessment_templates_created AssessmentTemplate[]       @relation("assessment_template_creator")
  ai_instructions_submitted    AiGradingInstruction[]     @relation("ai_instruction_submitter")
  ai_instructions_reviewed     AiGradingInstruction[]     @relation("ai_instruction_reviewer")
  ai_references_uploaded       AiGradingReference[]       @relation("ai_reference_uploader")
  ai_references_reviewed       AiGradingReference[]       @relation("ai_reference_reviewer")
  grade_curves_applied         GradeCurveAudit[]          @relation("curve_applicant")
  assessment_grades_published  Assessment[]               @relation("assessment_grade_publisher")
  risk_alerts_acknowledged     StudentAcademicRiskAlert[] @relation("risk_alert_acknowledger")
  progress_reports_generated   ProgressReport[]           @relation("progress_report_generator")
  nl_query_history             NlQueryHistory[]

  // Report Cards Enhancement Relations
  report_card_templates_created     ReportCardTemplate[]         @relation("report_card_template_creator")
  report_card_approvals_actioned    ReportCardApproval[]         @relation("report_card_approval_actioner")
  report_card_batch_jobs_requested  ReportCardBatchJob[]         @relation("batch_job_requester")
  report_card_custom_fields_entered ReportCardCustomFieldValue[] @relation("custom_field_enterer")

  // Scheduling World-Class Relations
  absences_reported            TeacherAbsence[]            @relation("absence_reporter")
  substitutions_assigned       SubstitutionRecord[]        @relation("substitution_assigner")
  calendar_subscription_tokens CalendarSubscriptionToken[] @relation("calendar_token_owner")
  scheduling_scenarios_created SchedulingScenario[]        @relation("scenario_creator")

  @@map("users")
}

/// Append-only, no updated_at
model MfaRecoveryCode {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  code_hash  String    @db.Text
  used_at    DateTime? @db.Timestamptz()
  created_at DateTime  @default(now()) @db.Timestamptz()

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], name: "idx_mfa_recovery_user")
  @@map("mfa_recovery_codes")
}

/// Append-only, no updated_at
model PasswordResetToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @db.Text
  expires_at DateTime  @db.Timestamptz()
  used_at    DateTime? @db.Timestamptz()
  created_at DateTime  @default(now()) @db.Timestamptz()

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], name: "idx_password_reset_tokens_user")
  @@map("password_reset_tokens")
}

