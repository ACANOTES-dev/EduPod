  booked_by User               @relation("eng_conf_booker", fields: [booked_by_user_id], references: [id])

  @@index([tenant_id, student_id], name: "idx_conf_bookings_student")
  @@map("conference_bookings")
}

model EngagementIncidentReport {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String   @db.Uuid
  event_id            String   @db.Uuid
  title               String   @db.VarChar(255)
  description         String   @db.Text
  reported_by_user_id String   @db.Uuid
