  updated_at           DateTime            @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  tenant           Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  staff_profile    StaffProfile  @relation(fields: [staff_profile_id], references: [id], onDelete: Cascade)
  schedule         Schedule      @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
  substitute_staff StaffProfile? @relation("substitute_staff", fields: [substitute_staff_id], references: [id], onDelete: SetNull)
  confirmed_by     User?         @relation("delivery_confirmer", fields: [confirmed_by_user_id], references: [id], onDelete: SetNull)

  @@unique([tenant_id, staff_profile_id, schedule_id, delivery_date], name: "idx_class_delivery_unique")
  @@index([tenant_id, staff_profile_id, delivery_date], name: "idx_class_delivery_tenant_staff_date")
  @@map("class_delivery_records")
}

model PayrollAdjustment {
