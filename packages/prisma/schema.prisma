  tenant_id                        String          @db.Uuid
  granted_to_id                    String          @db.Uuid
  granted_by_id                    String          @db.Uuid
  reason                           String          @db.Text
  scope                            BreakGlassScope @default(all_concerns)
  scoped_concern_ids               String[]        @db.Uuid
  granted_at                       DateTime        @db.Timestamptz()
  expires_at                       DateTime        @db.Timestamptz()
  revoked_at                       DateTime?       @db.Timestamptz()
  after_action_review_required     Boolean         @default(true)
  after_action_review_completed_at DateTime?       @db.Timestamptz()
  after_action_review_by_id        String?         @db.Uuid
  after_action_review_notes        String?         @db.Text
  created_at                       DateTime        @default(now()) @db.Timestamptz()

  // Relations
  tenant                 Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  granted_to             User   @relation("sg_break_glass_grantee", fields: [granted_to_id], references: [id], onDelete: Cascade)
  granted_by             User   @relation("sg_break_glass_grantor", fields: [granted_by_id], references: [id], onDelete: Cascade)
  after_action_review_by User?  @relation("sg_break_glass_reviewer", fields: [after_action_review_by_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, granted_to_id], name: "idx_safeguarding_break_glass_grantee")
  @@map("safeguarding_break_glass_grants")
}

